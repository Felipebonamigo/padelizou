@model Padelizou.Models.Torneio
@{
    var aberto = Model.Status == "Inscrições Abertas";
    var textoBotao = aberto ? "Ver Torneio e Inscrever-se" : (Model.Status == "Finalizado" ? "Ver Resultado" : "Ver Torneio");
}
<div class="col" data-torneio-nome="@Model.Nome.ToLower()">
    <div class="card h-100 shadow-sm border-0 overflow-hidden">
        @if (!string.IsNullOrEmpty(Model.ImagemCapa))
        {
            <div style="height: 150px; overflow: hidden;">
                <img src="@Model.ImagemCapa" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
        }
        else
        {
            <div style="height: 150px; background: linear-gradient(125deg, var(--pdz-navy-900), var(--padel-blue) 60%, #29396a); display:flex; align-items:center; justify-content:center;">
                <img src="~/image/logo-icon.png" style="height: 64px; opacity: 0.92; filter: drop-shadow(0 6px 14px rgba(0,0,0,.3));" />
            </div>
        }

        <div class="card-body">
            <h5 class="card-title fw-bold" style="color: var(--padel-blue);">@Model.Nome</h5>
            <p class="card-text text-muted small mb-1">
                <i class="bi bi-geo-alt-fill"></i> Local: @(string.IsNullOrEmpty(Model.LocalTorneio) ? "A definir" : Model.LocalTorneio)
            </p>
            <p class="card-text text-muted small">
                <i class="bi bi-cash"></i> Inscrição: @Model.PrecoInscricao.ToString("C")
            </p>
        </div>
        <div class="card-footer bg-white border-0 pb-3 text-center">
            <a asp-controller="Torneios" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-padel w-100 rounded-pill">
                <i class="bi bi-card-checklist me-2"></i> @textoBotao
            </a>
        </div>
    </div>
</div>
