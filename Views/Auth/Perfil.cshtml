@model Padelizou.Models.Jogador
@{
    ViewData["Title"] = "Meu Perfil";
}

<div class="container mt-4">
    <div class="row">
        <!-- Coluna da Esquerda: Resumo do Jogador -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <i class="bi bi-person-circle display-1" style="color: var(--padel-blue);"></i>
                <h3 class="mt-3 fw-bold mb-0">@Model.Nome</h3>
                <p class="text-muted mb-3"><i class="bi bi-geo-alt"></i> @(Model.Cidade ?? "Cidade não informada") - @(Model.Estado ?? "UF")</p>

                <div class="p-3 rounded-3 mt-2" style="background-color: var(--padel-blue); color: white;">
                    <p class="mb-0 small text-uppercase" style="letter-spacing: 1px;">Ranking Global</p>
                    <h1 class="display-5 fw-bold" style="color: var(--padel-green);">@Model.PontuacaoGlobal <span class="fs-6 text-light">pts</span></h1>
                </div>
                <a asp-controller="Agenda" asp-action="Index" class="btn btn-padel mt-4 rounded-pill w-100 fw-bold shadow-sm">
                    <i class="bi bi-calendar3 me-1"></i> Minha Agenda
                </a>
                @if (Model.IsProfessor)
                {
                    <a asp-controller="Aulas" asp-action="MinhaAgenda" class="btn btn-warning mt-3 rounded-pill w-100 fw-bold shadow-sm" style="color: var(--padel-blue);">
                        <i class="bi bi-journal-bookmark-fill me-1"></i> Gerenciar Aulas (Professor)
                    </a>
                }
                <a asp-controller="Auth" asp-action="Preferencias" class="btn btn-outline-primary mt-3 rounded-pill w-100">
                    <i class="bi bi-sliders me-1"></i> Minhas Preferências
                </a>
                <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger mt-3 rounded-pill w-100">Sair da Conta</a>
            </div>
        </div>

        <!-- Coluna da Direita: Atividades e Painel -->
        <div class="col-md-8">
            <h4 class="mb-3 fw-bold" style="color: var(--padel-blue);">Meu Painel</h4>

            <div class="row mb-4">
                <!-- Card de Torneios -->
                <div class="col-sm-6 mb-3">
                    <div class="card border-0 bg-light h-100 p-3 d-flex flex-column">
                        <h6 class="fw-bold text-muted"><i class="bi bi-trophy"></i> Meus Torneios</h6>
                        <p class="small mb-2">Títulos, confrontos e histórico completo de torneios.</p>
                        <a asp-controller="Jogadores" asp-action="Perfil" asp-route-id="@Model.Id" class="btn btn-sm btn-padel rounded-pill px-4 fw-bold mt-auto align-self-start">
                            Ver Meu Histórico
                        </a>
                    </div>
                </div>
                <!-- Card de Grupos Privados -->
                <div class="col-sm-6 mb-3">
                    <div class="card border-0 bg-light h-100 p-3">
                        <h6 class="fw-bold text-muted"><i class="bi bi-shield-lock-fill"></i> Meus Grupos (Painelinha)</h6>
                        @{
                            var meusGrupos = (List<JogadorGrupo>)ViewBag.MeusGrupos;
                        }
                        @if (meusGrupos.Any())
                        {
                            @foreach (var jg in meusGrupos.Take(2))
                            {
                                <div class="d-flex align-items-center mt-2 p-2 bg-white rounded shadow-sm border">
                                    <i class="bi bi-shield-lock-fill text-success fs-4 me-2"></i>
                                    <div>
                                        <strong class="d-block text-dark small">@jg.GrupoPrivado.Nome</strong>
                                        <span class="text-muted" style="font-size: 0.75rem;">Ranking Interno: @jg.PontuacaoInterna pts</span>
                                    </div>
                                </div>
                            }
                            <a asp-controller="Grupos" asp-action="Index" class="small mt-2 d-block">Ver todos os grupos</a>
                        }
                        else
                        {
                            <p class="small text-muted mt-2 mb-2">Você ainda não está em nenhum grupo.</p>
                            <a asp-controller="Grupos" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill">Criar ou entrar em um grupo</a>
                        }
                    </div>
                </div>
                <!-- Card de Aulas -->
                <div class="col-sm-12 mb-3 mt-3">
                    <div class="card border-0 bg-light p-3 d-flex flex-row justify-content-between align-items-center shadow-sm" style="border-radius: 12px;">
                        <div>
                            <h6 class="fw-bold mb-1" style="color: var(--padel-blue);"><i class="bi bi-calendar-check"></i> Minhas Aulas</h6>
                            <p class="small text-muted mb-0">Acesse seus treinos agendados e histórico.</p>
                        </div>
                        <a asp-controller="Aulas" asp-action="MinhasAulas" class="btn btn-sm btn-padel rounded-pill px-4 fw-bold">Ver Aulas</a>
                    </div>
                </div>
                <!-- Card de Avisos de Jogo -->
                <div class="col-sm-12 mb-3">
                    <div class="card border-0 bg-light p-3 d-flex flex-row justify-content-between align-items-center shadow-sm" style="border-radius: 12px;">
                        <div>
                            <h6 class="fw-bold mb-1" style="color: var(--padel-blue);"><i class="bi bi-megaphone-fill"></i> Buscar Jogo</h6>
                            <p class="small text-muted mb-0">Veja quem está procurando jogadores ou crie seu aviso.</p>
                        </div>
                        <a asp-controller="Avisos" asp-action="Index" class="btn btn-sm btn-padel rounded-pill px-4 fw-bold">Ver Avisos</a>
                    </div>
                </div>
            </div>

            <!-- Procurar Parceiro para Torneio -->
            <div class="p-4 rounded-3 text-center" style="background-color: #e9ecef; border: 2px dashed #ced4da;">
                <i class="bi bi-search fs-2 text-muted"></i>
                <h5 class="mt-2 fw-bold text-secondary">Procurando Parceiro?</h5>
                <p class="text-muted small">Veja vagas abertas ou anuncie que você está sem dupla pra um torneio.</p>
                <a asp-controller="Parceiros" asp-action="Index" class="btn btn-padel rounded-pill">Ver Vagas de Parceiro</a>
            </div>
        </div>
    </div>
</div>