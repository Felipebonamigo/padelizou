@{
    ViewData["Title"] = "Entrar - Padelizou";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0" style="border-top: 4px solid var(--padel-green);">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <img src="~/image/logo-icon.png" alt="Padelizou" style="height: 60px;" />
                        <h3 class="mt-3 fw-bold" style="color: var(--padel-blue);">Área do Jogador</h3>
                    </div>

                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert alert-danger text-center">@ViewBag.Erro</div>
                    }

                    <form asp-controller="Auth" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">E-mail</label>
                            <input type="email" name="email" class="form-control form-control-lg" required placeholder="seu@email.com" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted">Senha</label>
                            <input type="password" name="senha" class="form-control form-control-lg" required placeholder="••••••••" />
                        </div>
                        <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill">Entrar na Quadra</button>
                        <div class="text-center mt-4">
                            <a asp-action="Cadastro" class="text-decoration-none fw-bold" style="color: var(--padel-blue);">Ainda não tem conta? Cadastre-se</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>