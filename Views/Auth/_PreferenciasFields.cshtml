@model Padelizou.ViewModels.PreferenciasViewModel
@{
    var catalogoCategorias = (List<CategoriaPadrao>)ViewBag.CatalogoCategorias;
    var catalogoClubes = (List<Clube>)ViewBag.CatalogoClubes;
    string[] diasSemana = { "Domingo", "Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado" };
    string[] periodos = { "Manhã", "Tarde", "Noite" };
}

<!-- Lado da quadra -->
<div class="mb-4">
    <label class="form-label fw-bold text-muted small d-block">Lado que joga</label>
    <div class="btn-group w-100" role="group">
        <input type="radio" class="btn-check" name="ladoQuadra" id="ladoEsquerda" value="Esquerda" autocomplete="off" @(Model.LadoQuadra == "Esquerda" ? "checked" : "") />
        <label class="btn btn-outline-primary" for="ladoEsquerda">Esquerda</label>

        <input type="radio" class="btn-check" name="ladoQuadra" id="ladoDireita" value="Direita" autocomplete="off" @(Model.LadoQuadra == "Direita" ? "checked" : "") />
        <label class="btn btn-outline-primary" for="ladoDireita">Direita</label>

        <input type="radio" class="btn-check" name="ladoQuadra" id="ladoAmbos" value="Ambos" autocomplete="off" @(Model.LadoQuadra == "Ambos" || string.IsNullOrEmpty(Model.LadoQuadra) ? "checked" : "") />
        <label class="btn btn-outline-primary" for="ladoAmbos">Ambos</label>
    </div>
</div>

<!-- Instagram -->
<div class="mb-4">
    <label class="form-label fw-bold text-muted small d-block" for="instagramInput">Instagram</label>
    <div class="input-group">
        <span class="input-group-text">@@</span>
        <input type="text" class="form-control" name="instagram" id="instagramInput" placeholder="seu.usuario" value="@Model.Instagram" />
    </div>
    <small class="text-muted d-block mt-1">Aparece no seu perfil pra outros jogadores te encontrarem. Deixe em branco pra não mostrar.</small>
</div>

<!-- Notificações -->
<div class="mb-4 p-3 rounded" style="background-color: #f8f9fa;">
    <label class="form-label fw-bold text-muted small d-block mb-2">Como quer ser avisado de novos jogos?</label>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" name="notificarEmail" value="true" id="notifEmail" style="transform: scale(1.2);" @(Model.NotificarEmail ? "checked" : "") />
        <label class="form-check-label" for="notifEmail">Receber por e-mail</label>
    </div>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" name="notificarWhatsApp" value="true" id="notifWhats" style="transform: scale(1.2);" @(Model.NotificarWhatsApp ? "checked" : "") />
        <label class="form-check-label" for="notifWhats">Receber por WhatsApp</label>
    </div>
    <small class="text-muted d-block mt-2">Desmarque os dois pra parar de receber avisos. Pode mudar isso quando quiser.</small>
</div>

<!-- Convites de jogo avulso -->
<div class="mb-4 p-3 rounded" style="background-color: #f8f9fa;">
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" name="aceitaConvitesJogo" value="true" id="aceitaConvites" style="transform: scale(1.2);" @(Model.AceitaConvitesJogo ? "checked" : "") />
        <label class="form-check-label fw-bold" for="aceitaConvites">Aceito ser convidado pra jogos avulsos de grupos</label>
    </div>
    <small class="text-muted d-block mt-2">Quando o organizador de um grupo precisar de gente de fora pra completar o jogo da semana, ele pode te chamar pelo WhatsApp — respeitando as categorias, locais e dias/horários que você marcou abaixo.</small>
</div>

<!-- Categorias -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
        <label class="form-label fw-bold text-muted small mb-0">Categorias que aceita jogar</label>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="desmarcarTodos('categoria')">Aceito qualquer categoria</button>
    </div>
    <div class="row">
        <div class="col-md-6 mb-2">
            <h6 class="small fw-bold text-muted"><i class="bi bi-gender-male"></i> Masculina</h6>
            @foreach (var cat in catalogoCategorias.Where(c => c.Tipo == "Masculina"))
            {
                <div class="form-check">
                    <input class="form-check-input categoria-check" type="checkbox" name="categoriasSelecionadas" value="@cat.Id" id="cat_@cat.Id" @(Model.CategoriasSelecionadas.Contains(cat.Id) ? "checked" : "") />
                    <label class="form-check-label small" for="cat_@cat.Id">@cat.Nome</label>
                </div>
            }
        </div>
        <div class="col-md-6 mb-2">
            <h6 class="small fw-bold text-muted"><i class="bi bi-gender-female"></i> Feminina</h6>
            @foreach (var cat in catalogoCategorias.Where(c => c.Tipo == "Feminina"))
            {
                <div class="form-check">
                    <input class="form-check-input categoria-check" type="checkbox" name="categoriasSelecionadas" value="@cat.Id" id="cat_@cat.Id" @(Model.CategoriasSelecionadas.Contains(cat.Id) ? "checked" : "") />
                    <label class="form-check-label small" for="cat_@cat.Id">@cat.Nome</label>
                </div>
            }
        </div>
    </div>
</div>

<!-- Locais preferidos -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
        <label class="form-label fw-bold text-muted small mb-0">Locais preferidos</label>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="desmarcarTodos('clube')">Qualquer local</button>
    </div>
    <div id="listaClubes">
        @foreach (var clube in catalogoClubes)
        {
            <div class="form-check form-check-inline">
                <input class="form-check-input clube-check" type="checkbox" name="clubesSelecionados" value="@clube.Id" id="clube_@clube.Id" @(Model.ClubesSelecionados.Contains(clube.Id) ? "checked" : "") />
                <label class="form-check-label small" for="clube_@clube.Id">@clube.Nome</label>
            </div>
        }
    </div>
    <div class="mt-2 d-flex gap-2 flex-wrap">
        <input type="text" id="novoClubeNome" class="form-control form-control-sm" placeholder="Nome de um novo clube" style="max-width: 220px;" />
        <button type="button" class="btn btn-sm btn-outline-primary" onclick="adicionarClube('novoClubeNome', 'listaClubes', 'clubesSelecionados')">
            <i class="bi bi-plus-circle"></i> Adicionar clube
        </button>
    </div>
</div>

<!-- Dias e períodos preferidos -->
<div class="mb-2">
    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
        <label class="form-label fw-bold text-muted small mb-0">Dias e períodos preferidos</label>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="desmarcarTodos('diahorario')">Qualquer horário</button>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle text-center">
            <thead>
                <tr>
                    <th class="text-start">Dia</th>
                    @foreach (var periodo in periodos)
                    {
                        <th>@periodo</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int dia = 0; dia < diasSemana.Length; dia++)
                {
                    <tr>
                        <td class="text-start small">@diasSemana[dia]</td>
                        @foreach (var periodo in periodos)
                        {
                            var valor = $"{dia}|{periodo}";
                            <td>
                                <input class="form-check-input diahorario-check" type="checkbox" name="diasHorariosSelecionados" value="@valor" @(Model.DiasHorariosSelecionados.Contains(valor) ? "checked" : "") />
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
