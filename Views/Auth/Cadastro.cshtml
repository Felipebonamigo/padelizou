@{
    ViewData["Title"] = "Cadastro - Padelizou";
    var catalogoCategorias = (List<CategoriaPadrao>)ViewBag.CatalogoCategorias;
    var catalogoClubes = (List<Clube>)ViewBag.CatalogoClubes;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0" style="border-top: 4px solid var(--padel-green);">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold" style="color: var(--pdz-ink);">Crie seu Perfil</h3>
                        <p class="text-muted">Junte-se ao Padelizou para acompanhar seu ranking e gerenciar seus jogos.</p>
                    </div>

                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert alert-danger text-center">@ViewBag.Erro</div>
                    }

                    <!-- ATENÇÃO AO ENCTYPE: Obrigatório para a foto funcionar -->
                    <form asp-controller="Auth" asp-action="Cadastro" method="post" enctype="multipart/form-data">

                        <!-- Dados Pessoais -->
                        <div class="row mb-3">
                            <div class="col-md-7">
                                <label class="form-label fw-bold text-muted small">Nome Completo</label>
                                <input type="text" name="nome" class="form-control bg-light" required placeholder="Ex: Felipe ou Bona" />
                            </div>
                            <div class="col-md-5 mt-3 mt-md-0">
                                <label class="form-label fw-bold text-muted small">CPF (Apenas números)</label>
                                <input type="text" name="cpf" class="form-control bg-light" required placeholder="000.000.000-00" />
                            </div>
                        </div>

                        <!-- Dados de Acesso -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Login</label>
                            <input type="text" name="login" class="form-control bg-light" required placeholder="Ex: felipe.bona" />
                            <small class="text-muted d-block mt-1">Precisa ser único. Usado por organizadores de torneio pra te encontrar e te adicionar como organizador.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">E-mail</label>
                            <input type="email" name="email" class="form-control bg-light" required placeholder="seu@email.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Celular / WhatsApp</label>
                            <input type="tel" name="celular" class="form-control bg-light" placeholder="(51) 99999-9999" />
                            <small class="text-muted d-block mt-1">Usado pra te avisar de jogos e convites por WhatsApp. Deixe em branco se preferir não informar.</small>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Senha</label>
                            <input type="password" name="senha" class="form-control bg-light" required placeholder="••••••••" />
                        </div>

                        <!-- O Switch Inteligente de Professor -->
                        <div class="mb-4 p-3 rounded" style="background-color: #f8f9fa; border-left: 4px solid var(--pdz-navy-fixed);">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="isProfessor" value="true" id="switchProfessor" style="transform: scale(1.3); margin-right: 10px;">
                                <label class="form-check-label fw-bold" for="switchProfessor" style="color: var(--pdz-ink);">
                                    Sou Professor de Padel
                                </label>
                            </div>
                            <small class="text-muted d-block mt-2">Marque esta opção se você deseja receber agendamentos de aulas e gerenciar sua agenda no sistema.</small>
                        </div>

                        <!-- Upload da Foto -->
                        <div class="mb-4 p-3 rounded" style="border: 2px dashed #dee2e6;">
                            <label class="form-label fw-bold text-muted mb-2">
                                <i class="bi bi-camera-fill me-1"></i> Foto de Perfil (Opcional)
                            </label>
                            <input type="file" name="foto" class="form-control" accept="image/*" />
                            <small class="text-muted d-block mt-1">Formatos aceitos: JPG ou PNG.</small>
                        </div>

                        <hr class="my-4" />
                        <h5 class="fw-bold text-muted mb-3">Preferências de jogo</h5>
                        <p class="small text-muted mt-n2 mb-3">
                            Usamos isso pra te avisar de jogos que combinam com você. Pode deixar em branco
                            (ou usar os botões "qualquer") e mudar tudo depois em "Minhas Preferências".
                        </p>

                        <partial name="_PreferenciasFields" model="@(new Padelizou.ViewModels.PreferenciasViewModel())" />

                        <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill mt-4">Finalizar Cadastro</button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-action="Login" class="text-decoration-none fw-bold" style="color: var(--pdz-ink);">Já tem uma conta? Faça Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>