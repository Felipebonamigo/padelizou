@{
    ViewData["Title"] = "Reportar Problema - Padelizou";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold" style="color: var(--padel-blue);">Reportar Problema</h2>
                    <p class="text-muted mb-0">Encontrou um bug ou algo que não funcionou? Nos conte aqui.</p>
                </div>
                <a asp-controller="Auth" asp-action="Perfil" class="btn btn-outline-secondary rounded-pill">Voltar ao Perfil</a>
            </div>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-controller="Auth" asp-action="ReportarProblema" method="post">
                        @Html.AntiForgeryToken()
                        <label class="form-label fw-bold text-muted small d-block" for="mensagem">O que aconteceu?</label>
                        <textarea class="form-control" name="mensagem" id="mensagem" rows="6" placeholder="Descreva o problema com o máximo de detalhes possível..." required></textarea>
                        <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill mt-3">Enviar Relato</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
