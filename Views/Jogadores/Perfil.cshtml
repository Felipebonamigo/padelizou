@model (Padelizou.Models.Jogador jogador, List<Padelizou.Models.Dupla> historico)
@using Padelizou.ViewModels
@{
    ViewData["Title"] = "Perfil de " + Model.jogador.Nome;
    var meuConfronto = ViewBag.MeuConfronto as HeadToHeadVM;
    var confrontos = ViewBag.Confrontos as List<ConfrontoResumoVM> ?? new();
    var parceiros = ViewBag.Parceiros as List<ParceiroResumoVM> ?? new();
    var conquistas = ViewBag.Conquistas as List<ConquistaVM> ?? new();
    string[] diasSemana = { "Domingo", "Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado" };
    bool perfilBloqueado = ViewBag.PerfilBloqueado == true;
}

<div class="container mt-4">
    <!-- HEADER DO PERFIL -->
    <div class="text-center mb-4">
        <div class="mb-2">
            <a asp-action="Buscar" class="text-decoration-none small text-muted">
                <i class="bi bi-search"></i> Buscar outro jogador
            </a>
        </div>
        <img src="@(string.IsNullOrEmpty(Model.jogador.FotoPerfil) ? "/img/default-avatar.png" : Model.jogador.FotoPerfil)"
             class="rounded-circle shadow" style="width: 120px; height: 120px; object-fit: cover;" />
        <h3 class="fw-bold mt-3">
            @Model.jogador.Nome
            @if (!perfilBloqueado && (int)ViewBag.Titulos > 0)
            {
                <span class="badge rounded-pill ms-1 align-middle" style="background:#fff6df;color:#8a6d00;font-weight:600;" title="Campeão @ViewBag.Titulos vez(es)">
                    <i class="bi bi-trophy-fill"></i> @ViewBag.Titulos×
                </span>
            }
        </h3>

        @if (perfilBloqueado)
        {
            <p class="text-muted small"><i class="bi bi-lock-fill"></i> Este perfil é privado.</p>
        }
        else
        {
            <p class="text-muted">Ranking: <strong>@Model.jogador.PontuacaoGlobal pts</strong></p>

            @if (!string.IsNullOrWhiteSpace(Model.jogador.Instagram) || !string.IsNullOrWhiteSpace(Model.jogador.Celular))
            {
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    @if (!string.IsNullOrWhiteSpace(Model.jogador.Instagram))
                    {
                        <a href="https://instagram.com/@(Model.jogador.Instagram.TrimStart('@'))" target="_blank" rel="noopener"
                           class="btn btn-sm btn-outline-secondary rounded-pill">
                            <i class="bi bi-instagram"></i> @@@(Model.jogador.Instagram.TrimStart('@'))
                        </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.jogador.Celular))
                    {
                        var numeroLimpo = new string(Model.jogador.Celular.Where(char.IsDigit).ToArray());
                        <a href="https://wa.me/55@(numeroLimpo)" target="_blank" rel="noopener"
                           class="btn btn-sm btn-outline-success rounded-pill">
                            <i class="bi bi-whatsapp"></i> WhatsApp
                        </a>
                    }
                </div>
            }
        }
    </div>

    @if (!perfilBloqueado)
    {
    <!-- PERFIL DE JOGO (lado preferido / lateralidade) -->
    @if (!string.IsNullOrWhiteSpace(Model.jogador.LadoQuadra) || !string.IsNullOrWhiteSpace(Model.jogador.Lateralidade))
    {
        <div class="card border-0 shadow-sm mb-4 p-3">
            <h6 class="fw-bold mb-2"><i class="bi bi-person-badge"></i> Perfil de jogo</h6>
            <div class="row g-2">
                @if (!string.IsNullOrWhiteSpace(Model.jogador.LadoQuadra))
                {
                    <div class="col-6">
                        <small class="text-muted text-uppercase fw-bold d-block" style="font-size: 0.7rem;">Lado preferido</small>
                        <span class="fw-bold">@Model.jogador.LadoQuadra</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.jogador.Lateralidade))
                {
                    <div class="col-6">
                        <small class="text-muted text-uppercase fw-bold d-block" style="font-size: 0.7rem;">Lateralidade</small>
                        <span class="fw-bold">@Model.jogador.Lateralidade</span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- CLUBES E HORÁRIOS -->
    @if (Model.jogador.JogadorClubes.Any() || Model.jogador.JogadorDiasHorarios.Any())
    {
        <div class="card border-0 shadow-sm mb-4 p-3">
            @if (Model.jogador.JogadorClubes.Any())
            {
                <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 0.7rem;"><i class="bi bi-building"></i> Joga em</small>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var jc in Model.jogador.JogadorClubes)
                    {
                        <span class="badge rounded-pill bg-light text-dark border px-3 py-2">@jc.Clube.Nome</span>
                    }
                </div>
            }
            @if (Model.jogador.JogadorDiasHorarios.Any())
            {
                <small class="text-muted text-uppercase fw-bold d-block mb-1" style="font-size: 0.7rem;"><i class="bi bi-clock-history"></i> Dias e horários preferidos</small>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var dh in Model.jogador.JogadorDiasHorarios.OrderBy(d => d.DiaSemana))
                    {
                        <span class="badge rounded-pill bg-light text-dark border px-3 py-2">@diasSemana[dh.DiaSemana] · @dh.Periodo</span>
                    }
                </div>
            }
        </div>
    }

    <!-- CONQUISTAS -->
    @if (conquistas.Any())
    {
        <div class="card border-0 shadow-sm mb-4 p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="fw-bold mb-0"><i class="bi bi-award-fill text-warning"></i> Conquistas</h6>
                <small class="text-muted">@conquistas.Count(c => c.Conquistada)/@conquistas.Count</small>
            </div>
            <div class="row g-2">
                @foreach (var c in conquistas)
                {
                    <div class="col-3 text-center">
                        <div class="p-2 rounded-3 h-100 @(c.Conquistada ? "bg-light" : "bg-light opacity-50")">
                            <i class="bi @c.Icone fs-4 @(c.Conquistada ? "text-warning" : "text-muted")"></i>
                            <div class="small fw-bold mt-1">@c.Titulo</div>
                            <div style="font-size: 0.65rem;" class="@(c.Conquistada ? "text-success" : "text-muted")">
                                @(c.Conquistada ? "✓ conquistado" : "bloqueado")
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- CONFRONTO COM VOCÊ (ao ver o perfil de outra pessoa, estando logado) -->
    @if (meuConfronto != null)
    {
        <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, var(--padel-blue), #1b3a6b); color: #fff;">
            <div class="card-body">
                @if (meuConfronto.Jogos > 0)
                {
                    <h6 class="fw-bold text-uppercase small mb-3 opacity-75">
                        <i class="bi bi-people-fill"></i> Seu confronto com @Model.jogador.Nome.Split(' ')[0]
                    </h6>
                    <div class="row text-center g-2">
                        <div class="col-4"><h4 class="fw-bold mb-0">@meuConfronto.Jogos</h4><small class="opacity-75">Jogos</small></div>
                        <div class="col-4"><h4 class="fw-bold mb-0 text-success">@meuConfronto.Vitorias</h4><small class="opacity-75">Vitórias</small></div>
                        <div class="col-4"><h4 class="fw-bold mb-0 text-warning">@meuConfronto.Derrotas</h4><small class="opacity-75">Derrotas</small></div>
                    </div>
                    <div class="text-center mt-3">
                        <a asp-action="Confronto" asp-route-oponenteId="@Model.jogador.Id" class="btn btn-sm btn-light rounded-pill fw-bold">
                            Ver histórico completo
                        </a>
                    </div>
                }
                else
                {
                    <p class="mb-0 text-center"><i class="bi bi-info-circle"></i> Vocês ainda não se enfrentaram em nenhuma partida registrada.</p>
                }
            </div>
        </div>
    }

    <!-- JOGA SEMPRE COM / JOGOU CONTRA / RIVAIS (visível apenas no próprio perfil) -->
    @if (parceiros.Any())
    {
        <div class="card border-0 shadow-sm mb-4 p-3">
            <h6 class="fw-bold mb-1"><i class="bi bi-people-fill"></i> Joga sempre com</h6>
            <p class="text-muted small mb-2">A turma que joga junto.</p>
            <div class="row g-2 text-center">
                @foreach (var par in parceiros.Take(4))
                {
                    <div class="col-3">
                        <a asp-action="Perfil" asp-route-id="@par.Parceiro.Id" class="text-decoration-none text-dark">
                            <img src="@(string.IsNullOrEmpty(par.Parceiro.FotoPerfil) ? "/img/default-avatar.png" : par.Parceiro.FotoPerfil)"
                                 class="rounded-circle" style="width:48px;height:48px;object-fit:cover;" />
                            <div class="small fw-bold mt-1">@par.Parceiro.Nome.Split(' ')[0]</div>
                            <div class="text-muted" style="font-size:0.7rem;">@par.Jogos jogo(s)</div>
                        </a>
                    </div>
                }
            </div>
        </div>
    }

    @if (confrontos.Any())
    {
        <div class="card border-0 shadow-sm mb-4 p-3">
            <h6 class="fw-bold mb-1"><i class="bi bi-shuffle"></i> Jogou contra</h6>
            <div class="row g-2 text-center">
                @foreach (var c in confrontos.Take(4))
                {
                    <div class="col-3">
                        <a asp-action="Confronto" asp-route-oponenteId="@c.Oponente.Id" class="text-decoration-none text-dark">
                            <img src="@(string.IsNullOrEmpty(c.Oponente.FotoPerfil) ? "/img/default-avatar.png" : c.Oponente.FotoPerfil)"
                                 class="rounded-circle" style="width:48px;height:48px;object-fit:cover;" />
                            <div class="small fw-bold mt-1">@c.Oponente.Nome.Split(' ')[0]</div>
                            <div class="text-muted" style="font-size:0.7rem;">@c.Jogos confronto(s)</div>
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4 p-3">
            <h6 class="fw-bold mb-1"><i class="bi bi-lightning-fill text-danger"></i> Rivais</h6>
            <p class="text-muted small mb-2">Quem mais cruza a rede com você.</p>
            <div class="list-group list-group-flush">
                @foreach (var c in confrontos.Take(5))
                {
                    <a asp-action="Confronto" asp-route-oponenteId="@c.Oponente.Id"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                        <div>
                            <span class="fw-bold text-dark">@c.Oponente.Nome</span>
                            <div class="text-muted small">@c.Jogos confronto(s)</div>
                        </div>
                        <span class="badge rounded-pill @(c.Vitorias >= c.Derrotas ? "bg-success" : "bg-danger")">
                            @(c.Vitorias)V @(c.Derrotas)D
                        </span>
                    </a>
                }
            </div>
        </div>
    }

    <!-- CARDS DE ESTATÍSTICA (GRID MOBILE) -->
    <div class="row g-2 mb-4">
        <div class="col-3"><div class="card p-2 text-center shadow-sm"><small class="text-muted">Títulos</small><h5 class="fw-bold text-warning mb-0">@ViewBag.Titulos</h5></div></div>
        <div class="col-3"><div class="card p-2 text-center shadow-sm"><small class="text-muted">Finais</small><h5 class="fw-bold text-primary mb-0">@ViewBag.Finais</h5></div></div>
        <div class="col-3"><div class="card p-2 text-center shadow-sm"><small class="text-muted">Semis</small><h5 class="fw-bold text-info mb-0">@ViewBag.Semis</h5></div></div>
        <div class="col-3"><div class="card p-2 text-center shadow-sm"><small class="text-muted" style="font-size: 0.7rem;">Caiu na Chave</small><h5 class="fw-bold text-secondary mb-0">@ViewBag.CaiuNaChave</h5></div></div>
    </div>

    <!-- LISTA DE TORNEIOS -->
    <h5 class="fw-bold mb-3">Histórico de Torneios</h5>
    <div class="list-group shadow-sm mb-4">
        @if (!Model.historico.Any())
        {
            <p class="text-muted small mb-0"><i class="bi bi-info-circle"></i> Nenhum torneio registrado ainda.</p>
        }
        @foreach (var dupla in Model.historico)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                <div>
                    <h6 class="fw-bold mb-0">@dupla.Categoria.Torneio.Nome</h6>
                    <small class="text-muted">@dupla.Categoria.Nome · @dupla.Categoria.Torneio.DataInicio?.ToString("dd/MM/yyyy")</small>
                </div>
                <span class="badge rounded-pill @(dupla.UltimaFase == "Campeao" ? "bg-warning text-dark" : "bg-light text-dark border")">
                    @dupla.UltimaFase
                </span>
            </div>
        }
    </div>
    }
</div>
