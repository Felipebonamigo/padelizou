@model Padelizou.Models.Jogador

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Jogador</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cpf" class="control-label"></label>
                <input asp-for="Cpf" class="form-control" />
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Codigo" class="control-label"></label>
                <input asp-for="Codigo" class="form-control" />
                <span asp-validation-for="Codigo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DuplaJogador1s" class="control-label"></label>
                <input asp-for="DuplaJogador1s" class="form-control" />
                <span asp-validation-for="DuplaJogador1s" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DuplaJogador2s" class="control-label"></label>
                <input asp-for="DuplaJogador2s" class="form-control" />
                <span asp-validation-for="DuplaJogador2s" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="TimeId" class="control-label">Seu Time (Equipe)</label>
                <select asp-for="TimeId" class="form-select" asp-items="ViewBag.Times">
                    <!-- Esta option vazia é importante para quem ainda não tem time -->
                    <option value="">-- Sem time definido --</option>
                </select>
                <span asp-validation-for="TimeId" class="text-danger"></span>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
