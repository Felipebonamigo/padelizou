@model IEnumerable<Padelizou.Models.Torneio>
@{
    ViewData["Title"] = "Torneios de Padel";
}

<!-- Banner Hero -->
<div class="pdz-hero text-center mb-5">
    <span class="pdz-eyebrow"><i class="bi bi-lightning-charge-fill"></i> Bem-vindo ao Padelizou</span>
    <h1 class="display-4 fw-bold mb-2">Encontre seu próximo desafio.</h1>
    <p class="lead mb-4">Inscreva sua dupla, marque aulas, busque parceiros e suba no ranking — tudo num lugar só.</p>
    <div class="d-flex flex-wrap gap-2 justify-content-center">
        <a asp-controller="Avisos" asp-action="Index" class="btn btn-padel btn-lg rounded-pill px-4">
            <i class="bi bi-megaphone me-1"></i> Buscar um Jogo
        </a>
        <a asp-controller="Aulas" asp-action="Solicitar" class="btn btn-lg pdz-btn-ghost rounded-pill px-4">
            <i class="bi bi-calendar-plus me-1"></i> Marcar Aula
        </a>
    </div>
</div>

<!-- Grid de Torneios -->
<div class="container px-0">
    <h3 class="pdz-section-title mb-4">Torneios com Inscrições Abertas</h3>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var torneio in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 overflow-hidden">
                        <!-- Imagem Genérica para o card (depois podemos colocar o cartaz do torneio) -->
                        <div style="height: 150px; background: linear-gradient(125deg, var(--pdz-navy-900), var(--padel-blue) 60%, #29396a); display:flex; align-items:center; justify-content:center;">
                            <img src="~/image/logo-icon.png" style="height: 64px; opacity: 0.92; filter: drop-shadow(0 6px 14px rgba(0,0,0,.3));" />
                        </div>

                        <div class="card-body">
                            <h5 class="card-title fw-bold" style="color: var(--padel-blue);">@torneio.Nome</h5>
                            <p class="card-text text-muted small mb-1">
                                <i class="bi bi-geo-alt-fill"></i> Local: @(string.IsNullOrEmpty(torneio.LocalTorneio) ? "A definir" : torneio.LocalTorneio)
                            </p>
                            <p class="card-text text-muted small">
                                <i class="bi bi-cash"></i> Inscrição: @torneio.PrecoInscricao.ToString("C")
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3 text-center">
                            <!-- Esse botão vai levar para a nossa futura página de Detalhes/Abas -->
                            <a asp-controller="Torneios" asp-action="Details" asp-route-id="@torneio.Id" class="btn btn-padel w-100 rounded-pill">
                                <i class="bi bi-card-checklist me-2"></i> Ver Torneio e Inscrever-se
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted mt-4">
                <p>Nenhum torneio aberto no momento.</p>
            </div>
        }
    </div>
</div>