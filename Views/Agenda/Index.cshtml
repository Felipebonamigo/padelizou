@model List<Padelizou.ViewModels.AgendaItem>
@{
    ViewData["Title"] = "Minha Agenda - Padelizou";
    var jogador = (Jogador)ViewBag.Jogador;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold" style="color: var(--pdz-ink);">Minha Agenda</h2>
            <p class="text-muted mb-0">Tudo que você tem marcado, num só lugar.</p>
        </div>
        <a asp-controller="Auth" asp-action="Perfil" class="btn btn-outline-secondary rounded-pill">Voltar ao Perfil</a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold text-muted mb-3">O que aparece aqui?</h6>
            <form asp-controller="Agenda" asp-action="AtualizarPreferencias" method="post" class="d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mostrarAulas" value="true" id="chkAulas" @(jogador.AgendaMostrarAulas ? "checked" : "") />
                    <label class="form-check-label" for="chkAulas">Minhas Aulas</label>
                </div>
                @if (jogador.IsProfessor)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="mostrarAlunos" value="true" id="chkAlunos" @(jogador.AgendaMostrarAlunos ? "checked" : "") />
                        <label class="form-check-label" for="chkAlunos">Meus Alunos</label>
                    </div>
                }
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mostrarTorneios" value="true" id="chkTorneios" @(jogador.AgendaMostrarTorneios ? "checked" : "") />
                    <label class="form-check-label" for="chkTorneios">Meus Torneios</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mostrarJogosSemanais" value="true" id="chkJogos" @(jogador.AgendaMostrarJogosSemanais ? "checked" : "") />
                    <label class="form-check-label" for="chkJogos">Jogos Semanais (Grupos)</label>
                </div>
                <button type="submit" class="btn btn-sm btn-padel rounded-pill px-4">Salvar</button>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold text-muted mb-2">Assine sua agenda</h6>
            <p class="text-muted small mb-3">
                Cole este link no Google Agenda (Configurações → Adicionar agenda → Por URL),
                no Apple Calendar (Arquivo → Nova assinatura de calendário) ou no Outlook
                (Adicionar calendário → Da internet) para ver suas aulas, torneios e partidas
                direto no seu calendário — sem precisar entrar no Padelizou.
            </p>
            <div class="input-group mb-2">
                <input type="text" id="linkAgendaFeed" class="form-control form-control-sm"
                       value="@ViewBag.LinkFeedAgenda" readonly />
                <button class="btn btn-sm btn-outline-secondary" type="button" onclick="copiarLinkAgenda()">
                    Copiar link
                </button>
            </div>
            <form asp-controller="Agenda" asp-action="RegenerarTokenFeed" method="post"
                  onsubmit="return confirm('O link atual vai parar de funcionar. Continuar?');">
                <button type="submit" class="btn btn-sm btn-link text-danger p-0">
                    Gerar novo link (invalida o atual)
                </button>
            </form>
        </div>
    </div>

    <script>
        function copiarLinkAgenda() {
            const campo = document.getElementById('linkAgendaFeed');
            navigator.clipboard.writeText(campo.value).then(() => alert('Link copiado!'));
        }
    </script>

    <div class="d-flex flex-wrap gap-3 mb-3 small text-muted align-items-center">
        <span class="d-inline-flex align-items-center gap-1"><span class="pdz-legenda-dot" style="background:#1C2742;"></span> Aula</span>
        @if (jogador.IsProfessor)
        {
            <span class="d-inline-flex align-items-center gap-1"><span class="pdz-legenda-dot" style="background:#ffc107;"></span> Aluno</span>
        }
        <span class="d-inline-flex align-items-center gap-1"><span class="pdz-legenda-dot" style="background:#198754;"></span> Torneio</span>
        <span class="d-inline-flex align-items-center gap-1"><span class="pdz-legenda-dot" style="background:#0dcaf0;"></span> Jogo Semanal</span>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div id="pdzCalendario"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales/pt-br.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var elemento = document.getElementById('pdzCalendario');
            var calendario = new FullCalendar.Calendar(elemento, {
                locale: 'pt-br',
                height: 'auto',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
                },
                buttonText: { today: 'Hoje', month: 'Mês', week: 'Semana', day: 'Dia', list: 'Lista' },
                allDayText: 'Dia inteiro',
                events: '@Url.Action("EventosJson", "Agenda")',
                eventClick: function (info) {
                    info.jsEvent.preventDefault();
                    if (info.event.url) window.location.href = info.event.url;
                }
            });
            calendario.render();
        });
    </script>
    <style>
        .pdz-legenda-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

        .fc {
            --fc-border-color: var(--pdz-border);
            --fc-page-bg-color: transparent;
            --fc-neutral-bg-color: var(--pdz-surface-alt);
            --fc-list-event-hover-bg-color: var(--pdz-surface-alt);
            --fc-today-bg-color: rgba(163, 216, 39, .12);
            --fc-button-text-color: #fff;
            --fc-button-bg-color: var(--pdz-navy);
            --fc-button-border-color: var(--pdz-navy);
            --fc-button-hover-bg-color: var(--pdz-navy-900);
            --fc-button-hover-border-color: var(--pdz-navy-900);
            --fc-button-active-bg-color: var(--pdz-navy-900);
            --fc-button-active-border-color: var(--pdz-navy-900);
            font-family: var(--font-body);
            color: var(--pdz-ink);
        }

        .fc .fc-toolbar-title { font-family: var(--font-display); color: var(--pdz-ink); }
        .fc .fc-button { border-radius: 50px !important; text-transform: capitalize; box-shadow: none !important; }
        .fc .fc-daygrid-day-number, .fc .fc-col-header-cell-cushion { color: var(--pdz-ink); }
        .fc .fc-event { border-radius: 6px; cursor: pointer; }
        .fc-theme-standard td, .fc-theme-standard th { border-color: var(--pdz-border); }
        .fc-theme-standard .fc-scrollgrid { border-color: var(--pdz-border); }
    </style>
}
