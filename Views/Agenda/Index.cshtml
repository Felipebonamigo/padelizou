@model List<Padelizou.ViewModels.AgendaItem>
@{
    ViewData["Title"] = "Minha Agenda - Padelizou";
    var jogador = (Jogador)ViewBag.Jogador;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold" style="color: var(--padel-blue);">Minha Agenda</h2>
            <p class="text-muted mb-0">Tudo que você tem marcado, num só lugar.</p>
        </div>
        <a asp-controller="Auth" asp-action="Perfil" class="btn btn-outline-secondary rounded-pill">Voltar ao Perfil</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold text-muted mb-3">O que aparece aqui?</h6>
            <form asp-controller="Agenda" asp-action="AtualizarPreferencias" method="post" class="d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mostrarAulas" value="true" id="chkAulas" @(jogador.AgendaMostrarAulas ? "checked" : "") />
                    <label class="form-check-label" for="chkAulas">Minhas Aulas</label>
                </div>
                @if (jogador.IsProfessor)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="mostrarAlunos" value="true" id="chkAlunos" @(jogador.AgendaMostrarAlunos ? "checked" : "") />
                        <label class="form-check-label" for="chkAlunos">Meus Alunos</label>
                    </div>
                }
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mostrarTorneios" value="true" id="chkTorneios" @(jogador.AgendaMostrarTorneios ? "checked" : "") />
                    <label class="form-check-label" for="chkTorneios">Meus Torneios</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mostrarJogosSemanais" value="true" id="chkJogos" @(jogador.AgendaMostrarJogosSemanais ? "checked" : "") />
                    <label class="form-check-label" for="chkJogos">Jogos Semanais (Grupos)</label>
                </div>
                <button type="submit" class="btn btn-sm btn-padel rounded-pill px-4">Salvar</button>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="list-group shadow-sm">
            @foreach (var item in Model)
            {
                var badgeClass = item.Tipo switch
                {
                    "Aula" => "bg-primary",
                    "Aluno" => "bg-warning text-dark",
                    "Torneio" => "bg-success",
                    _ => "bg-info text-dark"
                };

                <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi @item.Icone fs-4 text-muted"></i>
                        <div>
                            <span class="badge @badgeClass mb-1">@item.Tipo</span>
                            <h6 class="mb-0 fw-bold" style="color: var(--padel-blue);">@item.Titulo</h6>
                            <span class="text-muted small">@item.Subtitulo</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold small">@item.Data.ToString("dd/MM/yyyy")</div>
                        @if (item.LinkController != null)
                        {
                            <a asp-controller="@item.LinkController" asp-action="@item.LinkAction" asp-route-id="@item.LinkId" class="small">Ver mais</a>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="col-12 text-center py-5 rounded-3 bg-light" style="border: 2px dashed #ccc;">
            <i class="bi bi-calendar3 display-4 text-muted mb-3"></i>
            <h4 class="fw-bold text-secondary">Nada por aqui ainda</h4>
            <p class="text-muted">Marque uma aula, entre num grupo ou se inscreva num torneio pra ver tudo aqui.</p>
        </div>
    }
</div>
