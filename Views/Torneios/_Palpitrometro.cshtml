@model (Padelizou.Models.Partida partida, Padelizou.ViewModels.PalpiteResumoVM? resumo, int? meuId)
@{
    var r = Model.resumo ?? new Padelizou.ViewModels.PalpiteResumoVM { PartidaId = Model.partida.Id };
    bool finalizada = Model.partida.Status == "Finalizada";
    bool logado = Model.meuId.HasValue;
    bool votavel = Model.partida.Status == "Agendada" && logado;
    int? meuVoto = r.MeuVotoDuplaId;
    string nome1 = $"{Model.partida.Dupla1?.Jogador1?.Nome?.Split(' ')[0]} / {Model.partida.Dupla1?.Jogador2?.Nome?.Split(' ')[0]}";
    string nome2 = $"{Model.partida.Dupla2?.Jogador1?.Nome?.Split(' ')[0]} / {Model.partida.Dupla2?.Jogador2?.Nome?.Split(' ')[0]}";
    bool galeraAcertou = finalizada && r.TotalVotos > 0
        && ((r.VotosDupla1 >= r.VotosDupla2 && Model.partida.VencedorId == Model.partida.Dupla1Id)
         || (r.VotosDupla2 > r.VotosDupla1 && Model.partida.VencedorId == Model.partida.Dupla2Id));
}
<div class="pdz-palpitrometro mt-2 pt-2 border-top text-start" data-partida-id="@Model.partida.Id">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <small class="text-muted fw-bold"><i class="bi bi-graph-up"></i> Palpitrômetro</small>
        @if (finalizada && r.TotalVotos > 0)
        {
            <small class="@(galeraAcertou ? "text-success" : "text-danger") fw-bold">
                <i class="bi @(galeraAcertou ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i> Galera @(galeraAcertou ? "acertou" : "errou")
            </small>
        }
    </div>

    @{
        bool dupla1Lidera = r.PercentualDupla1 >= r.PercentualDupla2;
    }
    <div class="d-flex justify-content-between small mb-1 gap-2">
        <span class="palpite-opcao text-truncate text-success @(votavel ? "votavel" : "") @(meuVoto == Model.partida.Dupla1Id ? "fw-bold" : "")" data-dupla-id="@Model.partida.Dupla1Id" data-votavel="@votavel.ToString().ToLower()" onclick="votarPalpite(this)">
            @(meuVoto == Model.partida.Dupla1Id ? "✓ " : "")@nome1
        </span>
        <span class="palpite-opcao text-truncate text-primary text-end @(votavel ? "votavel" : "") @(meuVoto == Model.partida.Dupla2Id ? "fw-bold" : "")" data-dupla-id="@Model.partida.Dupla2Id" data-votavel="@votavel.ToString().ToLower()" onclick="votarPalpite(this)">
            @(meuVoto == Model.partida.Dupla2Id ? "✓ " : "")@nome2
        </span>
    </div>

    <div class="pdz-palpite-barra-wrap">
        <div class="pdz-palpite-pct-badge text-success" data-pct="1" style="display: @(dupla1Lidera ? "block" : "none"); left: 0;">
            @r.PercentualDupla1%<i class="bi bi-caret-down-fill"></i>
        </div>
        <div class="pdz-palpite-pct-badge text-primary" data-pct="2" style="display: @(dupla1Lidera ? "none" : "block"); right: 0;">
            @r.PercentualDupla2%<i class="bi bi-caret-down-fill"></i>
        </div>
        <div class="progress" style="height: 10px;">
            <div class="progress-bar bg-success" data-bar="1" style="width: @(r.PercentualDupla1.ToString(System.Globalization.CultureInfo.InvariantCulture))%;"></div>
            <div class="progress-bar bg-primary" data-bar="2" style="width: @(r.PercentualDupla2.ToString(System.Globalization.CultureInfo.InvariantCulture))%;"></div>
        </div>
    </div>

    <div class="text-center mt-1">
        @if (!logado)
        {
            <small class="text-muted"><a asp-controller="Auth" asp-action="Login">Entre para palpitar</a> · <span class="pdz-total-votos">@r.TotalVotos voto(s)</span></small>
        }
        else
        {
            <small class="text-muted pdz-total-votos">@r.TotalVotos voto(s)</small>
        }
        @if (r.TotalVotos > 0)
        {
            <button type="button" class="btn btn-link btn-sm p-0 ms-2" data-partida-id="@Model.partida.Id" data-nome1="@nome1" data-nome2="@nome2" onclick="verVotos(this.dataset.partidaId, this.dataset.nome1, this.dataset.nome2)">
                Ver quem votou
            </button>
        }
    </div>
</div>
