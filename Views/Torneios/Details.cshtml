@model Padelizou.Models.Torneio
@using Padelizou.ViewModels
@{
    ViewData["Title"] = Model.Nome;
    var historico = ViewBag.HistoricoJogadores as Dictionary<int, Dictionary<string, HistoricoCategoriaVM>> ?? new Dictionary<int, Dictionary<string, HistoricoCategoriaVM>>();
    ViewData["Historico"] = historico;
}

<!-- Cabeçalho do Torneio -->
<div class="mb-4">
    <h2 class="fw-bold" style="color: var(--padel-blue);">@Model.Nome</h2>
    <p class="text-muted">
        <i class="bi bi-geo-alt-fill text-danger"></i> @(string.IsNullOrEmpty(Model.LocalTorneio) ? "A definir" : Model.LocalTorneio) |
        <i class="bi bi-cash text-success"></i> @Model.PrecoInscricao.ToString("C")
    </p>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<!-- Navegação das Abas -->
<ul class="nav nav-tabs" id="torneioTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold" id="inscritos-tab" data-bs-toggle="tab" data-bs-target="#inscritos" type="button" role="tab" style="color: var(--padel-blue);">
            <i class="bi bi-people-fill"></i> Inscritos
        </button>
    </li>

    <!-- Só mostra a aba de Inscrição se o status permitir -->
    @if (Model.Status == "Inscrições Abertas")
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold" id="inscricao-tab" data-bs-toggle="tab" data-bs-target="#inscricao" type="button" role="tab" style="color: var(--padel-green); background-color: var(--padel-blue);">
                <i class="bi bi-pencil-square"></i> Inscreva-se
            </button>
        </li>
    }

    <!-- Aba Exclusiva do Organizador -->
    @if (ViewBag.PodeGerenciar == true)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-danger" id="admin-tab" data-bs-toggle="tab" data-bs-target="#admin" type="button" role="tab">
                <i class="bi bi-gear-fill"></i> Gerenciar Torneio
            </button>
        </li>
    }
    @if (Model.Status != "Inscrições Abertas" && Model.Status != "Finalizado")
    {
        <li class="nav-item ms-auto" role="presentation">
            <button class="nav-link fw-bold text-danger" id="aovivo-tab" data-bs-toggle="tab" data-bs-target="#aovivo" type="button" role="tab">
                <span class="spinner-grow spinner-grow-sm me-1" role="status"></span> AO VIVO
            </button>
        </li>
    }
    <!-- Adicione isso logo após a aba "Ao Vivo" -->
    @if (Model.Status == "Fase de Grupos" || Model.Status == "Mata-Mata" || Model.Status == "Finalizado")
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold" id="grupos-tab" data-bs-toggle="tab" data-bs-target="#grupos" type="button" role="tab" style="color: var(--padel-blue);">
                <i class="bi bi-layout-split"></i> Chaves e Grupos
            </button>
        </li>
    }
</ul>

<!-- Conteúdo das Abas -->
<div class="tab-content border border-top-0 p-4 bg-white shadow-sm" id="torneioTabsContent" style="border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;">

    <!-- ABA 1: LISTA DE INSCRITOS -->
    <div class="tab-pane fade show active" id="inscritos" role="tabpanel">
        <h4 class="mb-3" style="color: var(--padel-blue);">@(Model.Formato == "Americano" ? "Inscritos" : "Duplas Confirmadas")</h4>
        @{
            var inscricoesAmericanas = ViewBag.InscricoesAmericanas as List<Padelizou.Models.InscricaoAmericana> ?? new();
        }

        @{
            int categoriaSelecionadaId = ViewBag.CategoriaSelecionadaId is int csid ? csid : 0;
        }
        <div class="mb-3">
            <label class="form-label fw-bold small">Categoria</label>
            <select id="seletorCategoriaInscritos" class="form-select" onchange="mostrarCategoriaInscritos(this.value)">
                @foreach (var cat in Model.Categorias)
                {
                    <option value="@cat.Id" selected="@(cat.Id == categoriaSelecionadaId)">@cat.Nome</option>
                }
            </select>
        </div>

        @foreach (var cat in Model.Categorias)
        {
            var inscritosAmericano = inscricoesAmericanas.Where(i => i.CategoriaId == cat.Id).ToList();
            ViewData["CategoriaAtual"] = cat.Nome;
            <div class="categoria-inscritos-conteudo" data-categoria-id="@cat.Id" style="display: @(cat.Id == categoriaSelecionadaId ? "block" : "none");">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    @if (Model.Formato == "Americano")
                    {
                        <span class="badge" style="background-color: var(--padel-blue);">@inscritosAmericano.Count inscritos</span>
                        <a asp-controller="Torneios" asp-action="ClassificacaoAmericano" asp-route-id="@Model.Id" asp-route-categoriaId="@cat.Id" class="btn btn-sm btn-outline-primary rounded-pill">
                            <i class="bi bi-list-ol"></i> Ver Classificação Individual
                        </a>
                    }
                    else
                    {
                        <span class="badge" style="background-color: var(--padel-blue);">@cat.Duplas.Count() duplas</span>
                    }
                </div>
                @if (Model.Formato == "Americano")
                {
                    @if (inscritosAmericano.Any())
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-3">
                            @foreach (var inscricao in inscritosAmericano)
                            {
                                <div class="col">
                                    <div class="border rounded p-3 h-100">
                                        <partial name="_JogadorChip" model="inscricao.Jogador" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0 small"><i class="bi bi-info-circle"></i> Nenhum jogador inscrito nesta categoria ainda.</p>
                    }
                }
                else if (cat.Duplas.Any())
                {
                    <div class="row row-cols-1 row-cols-md-2 g-3">
                        @foreach (var dupla in cat.Duplas)
                        {
                            <div class="col">
                                <div class="border rounded p-3 h-100">
                                    <partial name="_JogadorChip" model="dupla.Jogador1" />
                                    <partial name="_JogadorChip" model="dupla.Jogador2" />
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0 small"><i class="bi bi-info-circle"></i> Nenhuma dupla inscrita nesta categoria ainda.</p>
                }
            </div>
        }
    </div>

    <!-- ABA 2: FORMULÁRIO DE INSCRIÇÃO -->
    <div class="tab-pane fade" id="inscricao" role="tabpanel">
        <h4 class="mb-3" style="color: var(--padel-blue);">Formulário de Inscrição</h4>

        @if (Model.Formato == "Americano")
        {
            <form asp-controller="Torneios" asp-action="InscreverIndividual" method="post">
                <input type="hidden" name="torneioId" value="@Model.Id" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Selecione a Categoria</label>
                    <select name="categoriaId" class="form-select" required>
                        <option value="">-- Escolha uma categoria --</option>
                        @foreach (var cat in Model.Categorias)
                        {
                            <option value="@cat.Id">@cat.Nome</option>
                        }
                    </select>
                </div>

                <p class="text-muted small">No Torneio Americano a inscrição é individual — o sistema sorteia os parceiros a cada rodada.</p>

                <div class="mb-3">
                    <input type="text" name="nome" class="form-control mb-2" placeholder="Nome Completo" required />
                    <input type="text" name="cpf" class="form-control" placeholder="CPF (Apenas números)" required />
                </div>

                <button type="submit" class="btn btn-padel btn-lg w-100 mt-3 shadow-sm">
                    <i class="bi bi-check2-circle"></i> Confirmar Inscrição Individual
                </button>
            </form>
        }
        else
        {
        <form asp-controller="Duplas" asp-action="Create" method="post">
            <input type="hidden" name="torneioId" value="@Model.Id" />

            <div class="mb-4">
                <label class="form-label fw-bold">Selecione a Categoria</label>
                <select name="categoriaId" class="form-select" required>
                    <option value="">-- Escolha uma categoria --</option>
                    @foreach (var cat in Model.Categorias)
                    {
                        <option value="@cat.Id">@cat.Nome</option>
                    }
                </select>
            </div>

            <!-- Dados dos Jogadores -->
            <div class="row">
                <!-- JOGADOR 1 -->
                <div class="col-md-6">
                    <div class="card mb-3 border-0 bg-light">
                        <div class="card-header fw-bold text-white" style="background-color: var(--padel-blue);">Jogador 1</div>
                        <div class="card-body">
                            <input type="text" name="nome1" class="form-control mb-2" placeholder="Nome Completo" required />
                            <input type="text" name="cpf1" class="form-control mb-2" placeholder="CPF (Apenas números)" required />
                            <input type="text" name="celular1" class="form-control mb-2" placeholder="Celular (WhatsApp)" required />
                            <div class="row g-2">
                                <div class="col-8"><input type="text" name="cidade1" class="form-control" placeholder="Cidade" required /></div>
                                <div class="col-4"><input type="text" name="estado1" class="form-control" placeholder="UF" required /></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- JOGADOR 2 -->
                <div class="col-md-6">
                    <div class="card mb-3 border-0 bg-light">
                        <div class="card-header fw-bold text-white" style="background-color: var(--padel-blue);">Jogador 2</div>
                        <div class="card-body">
                            <input type="text" name="nome2" class="form-control mb-2" placeholder="Nome Completo" required />
                            <input type="text" name="cpf2" class="form-control mb-2" placeholder="CPF (Apenas números)" required />
                            <input type="text" name="celular2" class="form-control mb-2" placeholder="Celular (WhatsApp)" required />
                            <div class="row g-2">
                                <div class="col-8"><input type="text" name="cidade2" class="form-control" placeholder="Cidade" required /></div>
                                <div class="col-4"><input type="text" name="estado2" class="form-control" placeholder="UF" required /></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Regras de Impedimento Dinâmicas -->
            @if (Model.PermiteImpedimentos)
            {
                <div class="alert alert-warning mt-2 border-warning">
                    <h5 class="alert-heading fw-bold"><i class="bi bi-clock-history"></i> Restrições de Horário (Impedimentos)</h5>
                    <p class="mb-3 text-muted small">Marque abaixo apenas se a dupla for <strong>absolutamente incapaz</strong> de jogar nestes turnos. O excesso de impedimentos dificulta o chaveamento.</p>

                    @if (Model.PermiteImpedimentoSextaNoite)
                    {
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="impSextaNoite" value="true" id="impSexta">
                            <label class="form-check-label" for="impSexta">Não podemos jogar na <strong>Sexta à noite</strong></label>
                        </div>
                    }
                    @if (Model.PermiteImpedimentoSabadoManha)
                    {
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="impSabadoManha" value="true" id="impSabManha">
                            <label class="form-check-label" for="impSabManha">Não podemos jogar no <strong>Sábado de manhã</strong></label>
                        </div>
                    }
                    @if (Model.PermiteImpedimentoSabadoTarde)
                    {
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="impSabadoTarde" value="true" id="impSabTarde">
                            <label class="form-check-label" for="impSabTarde">Não podemos jogar no <strong>Sábado à tarde</strong></label>
                        </div>
                    }
                </div>
            }

            <button type="submit" class="btn btn-padel btn-lg w-100 mt-3 shadow-sm">
                <i class="bi bi-check2-circle"></i> Confirmar Inscrição da Dupla
            </button>
        </form>
        }
    </div>
    <!-- ABA 3: PAINEL DO ORGANIZADOR -->
    @if (ViewBag.PodeGerenciar == true)
    {
        <div class="tab-pane fade" id="admin" role="tabpanel">
            <h4 class="mb-3 text-danger"><i class="bi bi-gear-fill"></i> Painel de Controle</h4>

            <div class="card bg-light border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="fw-bold text-muted text-uppercase">Status Atual: <span class="badge bg-dark ms-2">@Model.Status</span></h6>
                    <hr />

                    @if (Model.Status == "Inscrições Abertas")
                    {
                        <div class="alert alert-warning border-warning">
                            <strong>Atenção:</strong> Ao encerrar as inscrições, o formulário será bloqueado para o público e você poderá gerar as chaves e os grupos.
                        </div>
                        <form asp-controller="Torneios" asp-action="EncerrarInscricoes" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-warning fw-bold shadow-sm">
                                <i class="bi bi-lock-fill"></i> Encerrar Inscrições
                            </button>
                        </form>
                    }
                    else if (Model.Status == "Chaves em Sorteio" && Model.Formato == "Americano")
                    {
                        <div class="alert alert-info border-info">
                            <strong>Inscrições Encerradas!</strong> Agora você pode sortear as rodadas — os parceiros vão trocar a cada rodada.
                        </div>
                        <form asp-controller="Torneios" asp-action="GerarRodadasAmericano" method="post" class="d-flex align-items-center gap-2 flex-wrap">
                            <input type="hidden" name="torneioId" value="@Model.Id" />
                            <input type="datetime-local" name="dataHoraInicio" class="form-control form-control-sm" style="width: auto;"
                                   value="@DateTime.Now.AddHours(1).ToString("yyyy-MM-ddTHH:mm")" required />
                            <button type="submit" class="btn btn-primary fw-bold shadow-sm">
                                <i class="bi bi-shuffle"></i> Sortear Rodadas do Americano
                            </button>
                        </form>
                    }
                    else if (Model.Status == "Chaves em Sorteio")
                    {
                        <div class="alert alert-info border-info">
                            <strong>Inscrições Encerradas!</strong> Agora você pode sortear os grupos. O sistema usará o Ranking Global para definir os Cabeças de Chave.
                        </div>
                        <form asp-controller="Torneios" asp-action="GerarChaves" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary fw-bold shadow-sm">
                                <i class="bi bi-diagram-3-fill"></i> Sortear Grupos e Gerar Chaves
                            </button>
                        </form>
                    }
                </div>
            </div>

            <!-- ORGANIZADORES DO TORNEIO -->
            <div class="card bg-light border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold text-muted text-uppercase mb-3">Organizadores deste Torneio</h6>

                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var org in (ViewBag.Organizadores as List<Padelizou.Models.TorneioOrganizador>) ?? new())
                        {
                            <li class="list-group-item bg-transparent d-flex align-items-center gap-2 px-0">
                                <img src="@(string.IsNullOrEmpty(org.Jogador.FotoPerfil) ? "/img/default-avatar.png" : org.Jogador.FotoPerfil)"
                                     class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;" />
                                <span class="fw-bold">@org.Jogador.Nome</span>
                                <span class="badge bg-secondary ms-2">@org.NivelAcesso</span>
                            </li>
                        }
                    </ul>

                    <label class="form-label fw-bold small">Adicionar novo organizador</label>
                    @{ ViewData["BuscaOrgTorneioId"] = Model.Id; }
                    <partial name="_BuscaOrganizador" />
                    @{ ViewData["BuscaOrgTorneioId"] = null; }
                </div>
            </div>

            <!-- EDITAR DADOS DO TORNEIO -->
            <div class="card bg-light border-0 shadow-sm mt-4">
                <div class="card-body">
                    <button class="btn btn-sm btn-outline-secondary rounded-pill mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#editarTorneioForm">
                        <i class="bi bi-pencil-square"></i> Editar Dados do Torneio
                    </button>
                    <div class="collapse" id="editarTorneioForm">
                        <form asp-controller="Torneios" asp-action="Editar" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Nome do Torneio</label>
                                    <input type="text" name="nome" class="form-control" value="@Model.Nome" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Local</label>
                                    <input type="text" name="localTorneio" class="form-control" value="@Model.LocalTorneio" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Clube</label>
                                    <select name="clubeId" class="form-select" required>
                                        @foreach (var clube in (ViewBag.CatalogoClubes as List<Padelizou.Models.Clube>) ?? new())
                                        {
                                            <option value="@clube.Id" selected="@(clube.Id == Model.ClubeId)">@clube.Nome</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Data de Início</label>
                                    <input type="date" name="dataInicio" class="form-control" value="@Model.DataInicio?.ToString("yyyy-MM-dd")" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Preço da Inscrição</label>
                                    <input type="number" step="0.01" name="precoInscricao" class="form-control" value="@Model.PrecoInscricao" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Qtd. de Quadras</label>
                                    <input type="number" id="editQuantidadeQuadras" name="quantidadeQuadras" class="form-control" value="@Model.QuantidadeQuadras" required oninput="gerarCamposQuadraEdicao()" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold small">Nome de cada Quadra</label>
                                    <div id="editCamposNomesQuadras" class="row g-2" data-nomes-atuais='@Html.Raw(System.Text.Json.JsonSerializer.Serialize((ViewBag.Quadras as List<Padelizou.Models.Quadra>)?.Select(q => q.Nome) ?? Enumerable.Empty<string>()))'></div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold small">Trocar Imagem de Capa</label>
                                    <input type="file" name="capa" class="form-control" accept="image/*" />
                                    @if (!string.IsNullOrEmpty(Model.ImagemCapa))
                                    {
                                        <img src="@Model.ImagemCapa" class="mt-2 rounded" style="max-height: 80px;" />
                                    }
                                </div>
                            </div>

                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="permiteImpedimentos" value="true" id="editImpSwitch" onchange="toggleImpedimentosEdicao()" @(Model.PermiteImpedimentos ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="editImpSwitch">Permitir Impedimentos de Horário?</label>
                            </div>
                            <div id="editTurnosImpedimento" class="ps-4 mb-3" style="display: @(Model.PermiteImpedimentos ? "block" : "none");">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="permiteImpedimentoSextaNoite" value="true" @(Model.PermiteImpedimentoSextaNoite ? "checked" : "")>
                                    <label class="form-check-label">Sexta à noite</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="permiteImpedimentoSabadoManha" value="true" @(Model.PermiteImpedimentoSabadoManha ? "checked" : "")>
                                    <label class="form-check-label">Sábado de manhã</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="permiteImpedimentoSabadoTarde" value="true" @(Model.PermiteImpedimentoSabadoTarde ? "checked" : "")>
                                    <label class="form-check-label">Sábado à tarde</label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-padel fw-bold shadow-sm">
                                <i class="bi bi-check-circle-fill"></i> Salvar Alterações
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- GERENCIAR INSCRITOS -->
            <div class="card bg-light border-0 shadow-sm mt-4">
                <div class="card-body">
                    <h6 class="fw-bold text-muted text-uppercase mb-3">Gerenciar Inscritos</h6>
                    @if (Model.Status == "Inscrições Abertas")
                    {
                        <p class="small text-muted">Pra adicionar um novo inscrito, use a aba <strong>Inscreva-se</strong>.</p>
                    }
                    @foreach (var cat in Model.Categorias)
                    {
                        <p class="fw-bold small mb-2 mt-3">@cat.Nome</p>
                        @if (cat.Duplas.Any())
                        {
                            <ul class="list-group list-group-flush mb-2">
                                @foreach (var dupla in cat.Duplas)
                                {
                                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0">
                                        <span>@dupla.Jogador1.Nome / @dupla.Jogador2.Nome</span>
                                        @if (Model.Status == "Inscrições Abertas")
                                        {
                                            <form asp-controller="Torneios" asp-action="RemoverDupla" method="post" onsubmit="return confirm('Remover esta dupla do torneio?');">
                                                <input type="hidden" name="duplaId" value="@dupla.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Remover
                                                </button>
                                            </form>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="small text-muted">Nenhuma dupla inscrita ainda.</p>
                        }
                    }
                </div>
            </div>
        </div>
    }
    <!-- ABA: AO VIVO -->
    @if (Model.Status != "Inscrições Abertas" && Model.Status != "Finalizado")
    {
        <div class="tab-pane fade" id="aovivo" role="tabpanel">
            <h4 class="mb-3 text-danger fw-bold"><i class="bi bi-broadcast"></i> Partidas em Andamento</h4>

            <!-- Esta DIV será preenchida automaticamente pelo JavaScript -->
            <div class="row" id="containerPlacaresAoVivo">
                <div class="col-12 text-center text-muted py-4">
                    <i class="bi bi-arrow-clockwise mb-2 fs-2 d-block"></i> Buscando jogos na quadra...
                </div>
            </div>
        </div>
    }
    <!-- ABA: CHAVES E GRUPOS -->
    <div class="tab-pane fade" id="grupos" role="tabpanel">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0 fw-bold" style="color: var(--padel-blue);">
                <i class="bi bi-layout-split"></i> Fase de Grupos
            </h4>
        </div>

        <!-- MENU DE CATEGORIAS (Rolagem Horizontal para Celular) -->
        <ul class="nav nav-pills flex-nowrap overflow-auto pb-2 mb-4" id="categoriaPills" role="tablist" style="-webkit-overflow-scrolling: touch; white-space: nowrap;">
            @{
                var primeiraCat = true;
            }
            @foreach (var categoria in Model.Categorias)
            {
                // Só mostra categorias que tenham grupos sorteados
                if (categoria.GruposTorneio != null && categoria.GruposTorneio.Any())
                {
                    <li class="nav-item me-2" role="presentation">
                        <button class="nav-link rounded-pill fw-bold border @(primeiraCat ? "active" : "")"
                                id="cat-@(categoria.Id)-tab" data-bs-toggle="pill" data-bs-target="#cat-@(categoria.Id)"
                                type="button" role="tab">
                            @categoria.Nome
                        </button>
                    </li>
                    primeiraCat = false;
                }
            }
        </ul>

        <!-- CONTEÚDO DOS GRUPOS POR CATEGORIA -->
        <div class="tab-content" id="categoriaPillsContent">
            @{
                var primeiraCatContent = true;
            }
            @foreach (var categoria in Model.Categorias)
            {
                if (categoria.GruposTorneio != null && categoria.GruposTorneio.Any())
                {
                    ViewData["CategoriaAtual"] = categoria.Nome;
                    <div class="tab-pane fade @(primeiraCatContent ? "show active" : "")" id="cat-@(categoria.Id)" role="tabpanel">
                        <!-- O cruzamento mata-mata é gerado automaticamente (TorneiosController.ProcessarMataMataAutomatico)
                             assim que a última partida da Fase de Grupos dessa categoria é finalizada — sem botão manual. -->
                        <div class="row">
                            @foreach (var grupo in categoria.GruposTorneio.OrderBy(g => g.Nome))
                            {
                                <div class="col-md-6 col-lg-4 mb-4">
                                    <div class="card shadow-sm border-0 h-100" style="border-top: 4px solid var(--padel-green);">
                                        <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
                                            <h5 class="fw-bold mb-0 text-center" style="color: var(--padel-blue);">@grupo.Nome</h5>
                                        </div>
                                        <div class="card-body p-0">
                                            <div class="table-responsive">
                                                <table class="table table-hover table-borderless mb-0 text-center align-middle">
                                                    <thead class="table-light text-muted small">
                                                        <tr>
                                                            <th class="text-start ps-3" style="width: 50%;">Dupla</th>
                                                            <th title="Jogos">J</th>
                                                            <th title="Vitórias" class="text-success">V</th>
                                                            <th title="Derrotas" class="text-danger">D</th>
                                                            <th title="Saldo de Games">SG</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <!-- Por enquanto listamos as duplas, a matemática do SG faremos no próximo passo -->
                                                        <!-- Dentro do tbody da tabela da fase de grupos, atualize estas colunas: -->
                                                        @foreach (var dupla in grupo.Duplas)
                                                        {
                                                            <tr style="border-bottom: 1px solid #f0f0f0;">
                                                                <td class="text-start ps-3 py-3" style="max-width: 180px;">
                                                                    <partial name="_JogadorChip" model="dupla.Jogador1" />
                                                                    <partial name="_JogadorChip" model="dupla.Jogador2" />
                                                                </td>

                                                                <!-- DADOS REAIS CALCULADOS PELO MOTOR -->
                                                                <td class="fw-bold text-secondary">@dupla.Jogos</td>
                                                                <td class="fw-bold text-success">@dupla.Vitorias</td>
                                                                <td class="fw-bold text-danger">@dupla.Derrotas</td>

                                                                <!-- Saldo de games ganha cor inteligente (Verde se +, Vermelho se -) -->
                                                                @if (dupla.SaldoGames > 0)
                                                                {
                                                                    <td class="fw-bold text-success">+@dupla.SaldoGames</td>
                                                                }
                                                                else if (dupla.SaldoGames < 0)
                                                                {
                                                                    <td class="fw-bold text-danger">@dupla.SaldoGames</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="fw-bold text-muted">0</td>
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mt-5 pt-3 border-top">
                            <h4 class="fw-bold mb-2" style="color: var(--padel-blue);">
                                <i class="bi bi-diagram-3-fill text-danger me-2"></i> Fase Final (Mata-Mata)
                            </h4>
                            <p class="text-muted small mb-4">Deslize para o lado para ver o chaveamento completo.</p>

                            <div class="bracket-container">

                                <!-- COLUNA: SEMIFINAIS -->
                                <div class="bracket-column">
                                    <div class="bracket-header">Semifinais</div>

                                    <!-- Confronto 1 -->
                                    <div class="bracket-match">
                                        <div class="bracket-team">
                                            <span class="team-name fw-bold text-muted text-truncate" style="max-width: 150px; font-size: 0.95rem;">1º Colocado Grupo A</span>
                                            <span class="fw-bold fs-5 text-secondary">-</span>
                                        </div>
                                        <div class="bracket-team">
                                            <span class="team-name fw-bold text-muted text-truncate" style="max-width: 150px; font-size: 0.95rem;">2º Colocado Grupo B</span>
                                            <span class="fw-bold fs-5 text-secondary">-</span>
                                        </div>
                                    </div>

                                    <!-- Confronto 2 -->
                                    <div class="bracket-match">
                                        <div class="bracket-team">
                                            <span class="team-name fw-bold text-muted text-truncate" style="max-width: 150px; font-size: 0.95rem;">1º Colocado Grupo B</span>
                                            <span class="fw-bold fs-5 text-secondary">-</span>
                                        </div>
                                        <div class="bracket-team">
                                            <span class="team-name fw-bold text-muted text-truncate" style="max-width: 150px; font-size: 0.95rem;">2º Colocado Grupo A</span>
                                            <span class="fw-bold fs-5 text-secondary">-</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- COLUNA: GRANDE FINAL -->
                                <div class="bracket-column" style="justify-content: center;">
                                    <div class="bracket-header text-danger"><i class="bi bi-trophy-fill"></i> Final</div>

                                    <div class="bracket-match" style="border: 2px solid var(--padel-blue);">
                                        <div class="bracket-team">
                                            <span class="team-name fw-bold text-muted text-truncate" style="max-width: 150px; font-size: 0.95rem;">Vencedor Semi 1</span>
                                            <span class="fw-bold fs-5 text-secondary">-</span>
                                        </div>
                                        <div class="bracket-team">
                                            <span class="team-name fw-bold text-muted text-truncate" style="max-width: 150px; font-size: 0.95rem;">Vencedor Semi 2</span>
                                            <span class="fw-bold fs-5 text-secondary">-</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- COLUNA: CAMPEÃO -->
                                <div class="bracket-column" style="justify-content: center; min-width: 200px;">
                                    <div class="text-center">
                                        <i class="bi bi-award-fill text-warning" style="font-size: 4rem; filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.2));"></i>
                                        <h5 class="fw-bold mt-2" style="color: var(--padel-blue);">Campeão</h5>
                                        <p class="text-muted small">Aguardando...</p>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    primeiraCatContent = false;
                }
            }
        </div>
    </div>
    <!-- SCRIPT DE ATUALIZAÇÃO AUTOMÁTICA (Coloque no final do arquivo Details.cshtml) -->
    <script>
            function carregarAoVivo() {
                if (!document.getElementById('containerPlacaresAoVivo')) return;
                fetch('/Torneios/ObterPlacaresAoVivo?torneioId=@Model.Id')
                    .then(response => response.json())
                    .then(partidas => {
                        const container = document.getElementById('containerPlacaresAoVivo');
                        if (partidas.length === 0) {
                            container.innerHTML = '<div class="alert alert-light text-center border w-100">Nenhum jogo rolando no momento.</div>';
                            return;
                        }

                        let html = '';
                        partidas.forEach(p => {
                            const selo = n => n > 0 ? ` <span class="badge rounded-pill" style="background:#fff6df;color:#8a6d00;font-weight:600;font-size:0.65rem;">🏆${n}×</span>` : '';
                            const nomeLink = (id, nome) => `<a href="/Jogadores/Perfil/${id}" style="color:inherit;text-decoration:underline;">${nome}</a>`;
                            const nomesD1 = `${nomeLink(p.jogador1IdD1, p.jogador1NomeD1)} / ${nomeLink(p.jogador2IdD1, p.jogador2NomeD1)}`;
                            const nomesD2 = `${nomeLink(p.jogador1IdD2, p.jogador1NomeD2)} / ${nomeLink(p.jogador2IdD2, p.jogador2NomeD2)}`;
                            html += `
                                                            <div class="col-md-6 mb-3">
                                                                <div class="card border-0 shadow-sm" style="border-top: 4px solid red;">
                                                                    <div class="card-body bg-dark text-light rounded-bottom p-3">
                                                                        <!-- DUPLA 1 -->
                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                            <span class="fw-bold text-truncate w-75">${nomesD1}${selo(p.titulosD1)}</span>
                                                                            <div class="fs-4 fw-bold">
                                                                                <span class="text-secondary fs-6 me-2">${p.setsD1}</span><span class="text-warning">${p.gamesD1}</span>
                                                                            </div>
                                                                        </div>
                                                                        <!-- DUPLA 2 -->
                                                                        <div class="d-flex justify-content-between align-items-center">
                                                                            <span class="fw-bold text-truncate w-75">${nomesD2}${selo(p.titulosD2)}</span>
                                                                            <div class="fs-4 fw-bold">
                                                                                <span class="text-secondary fs-6 me-2">${p.setsD2}</span><span class="text-warning">${p.gamesD2}</span>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>`;
                        });
                        container.innerHTML = html;
                    });
            }

            // Carrega a primeira vez e depois roda a cada 5 segundos
            carregarAoVivo();
            setInterval(carregarAoVivo, 5000);

            function mostrarCategoriaInscritos(categoriaId) {
                document.querySelectorAll('.categoria-inscritos-conteudo').forEach(function (el) {
                    el.style.display = (el.getAttribute('data-categoria-id') === String(categoriaId)) ? 'block' : 'none';
                });
            }

            function toggleImpedimentosEdicao() {
                var ligado = document.getElementById('editImpSwitch').checked;
                document.getElementById('editTurnosImpedimento').style.display = ligado ? 'block' : 'none';
            }

            function gerarCamposQuadraEdicao() {
                var container = document.getElementById('editCamposNomesQuadras');
                var quantidade = Math.max(0, Math.min(26, parseInt(document.getElementById('editQuantidadeQuadras').value, 10) || 0));
                var nomesAtuais = JSON.parse(container.getAttribute('data-nomes-atuais') || '[]');
                var valoresAtuais = Array.from(container.querySelectorAll('input')).map(function (i) { return i.value; });
                var valores = valoresAtuais.length > 0 ? valoresAtuais : nomesAtuais;

                container.innerHTML = '';
                for (var i = 0; i < quantidade; i++) {
                    var col = document.createElement('div');
                    col.className = 'col-md-3 col-6';
                    var input = document.createElement('input');
                    input.type = 'text';
                    input.name = 'nomesQuadras';
                    input.className = 'form-control form-control-sm';
                    input.placeholder = 'Quadra ' + String.fromCharCode(65 + i);
                    input.value = valores[i] || '';
                    col.appendChild(input);
                    container.appendChild(col);
                }
            }
            gerarCamposQuadraEdicao();
    </script>
</div>