@{
    ViewData["Title"] = "Torneios";
    var abertos = ViewBag.Abertos as List<Padelizou.Models.Torneio> ?? new();
    var emAndamento = ViewBag.EmAndamento as List<Padelizou.Models.Torneio> ?? new();
    var finalizados = ViewBag.Finalizados as List<Padelizou.Models.Torneio> ?? new();
}

<div class="container px-0 mt-4 mb-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <h2 class="fw-bold mb-0" style="color: var(--pdz-ink);"><i class="bi bi-trophy-fill"></i> Torneios</h2>
        <a asp-controller="Torneios" asp-action="Create" class="btn btn-padel rounded-pill px-4">
            <i class="bi bi-plus-circle-fill me-1"></i> Criar seu Torneio
        </a>
    </div>

    <div class="mb-4">
        <input type="text" id="buscaTorneioNome" class="form-control" placeholder="Buscar torneio pelo nome...">
    </div>

    <h5 class="pdz-section-title mb-3">Inscrições Abertas</h5>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5 torneio-secao" data-vazio="Nenhum torneio com inscrições abertas no momento.">
        @if (abertos.Any())
        {
            foreach (var torneio in abertos)
            {
                <partial name="_TorneioCard" model="torneio" />
            }
        }
        else
        {
            <div class="col-12 text-center text-muted"><p>Nenhum torneio com inscrições abertas no momento.</p></div>
        }
    </div>

    <h5 class="pdz-section-title mb-3">Em Andamento</h5>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5 torneio-secao" data-vazio="Nenhum torneio em andamento no momento.">
        @if (emAndamento.Any())
        {
            foreach (var torneio in emAndamento)
            {
                <partial name="_TorneioCard" model="torneio" />
            }
        }
        else
        {
            <div class="col-12 text-center text-muted"><p>Nenhum torneio em andamento no momento.</p></div>
        }
    </div>

    <h5 class="pdz-section-title mb-3">
        <button class="btn btn-sm btn-outline-secondary rounded-pill" type="button" data-bs-toggle="collapse" data-bs-target="#secaoFinalizados">
            Finalizados (@finalizados.Count) <i class="bi bi-chevron-down"></i>
        </button>
    </h5>
    <div class="collapse" id="secaoFinalizados">
        <div class="row row-cols-1 row-cols-md-3 g-4 torneio-secao" data-vazio="Nenhum torneio finalizado ainda.">
            @if (finalizados.Any())
            {
                foreach (var torneio in finalizados)
                {
                    <partial name="_TorneioCard" model="torneio" />
                }
            }
            else
            {
                <div class="col-12 text-center text-muted"><p>Nenhum torneio finalizado ainda.</p></div>
            }
        </div>
    </div>
</div>

<script>
    (function () {
        var input = document.getElementById('buscaTorneioNome');
        input.addEventListener('input', function () {
            var termo = input.value.trim().toLowerCase();
            document.querySelectorAll('.torneio-secao').forEach(function (secao) {
                var cards = secao.querySelectorAll('[data-torneio-nome]');
                var algumVisivel = false;
                cards.forEach(function (card) {
                    var visivel = card.getAttribute('data-torneio-nome').includes(termo);
                    card.style.display = visivel ? '' : 'none';
                    if (visivel) algumVisivel = true;
                });
                if (cards.length > 0) {
                    // Se tem cards de torneio nessa seção, só mostra "vazio" quando a busca não bate com nada
                    var semResultado = termo.length > 0 && !algumVisivel;
                    secao.querySelectorAll('.pdz-busca-sem-resultado').forEach(function (el) { el.remove(); });
                    if (semResultado) {
                        var aviso = document.createElement('div');
                        aviso.className = 'col-12 text-center text-muted pdz-busca-sem-resultado';
                        aviso.innerHTML = '<p>Nenhum torneio encontrado com esse nome.</p>';
                        secao.appendChild(aviso);
                    }
                    // Expande a seção de Finalizados automaticamente quando a busca encontra algo lá dentro
                    if (termo.length > 0 && algumVisivel) {
                        var colapsoFinalizados = document.getElementById('secaoFinalizados');
                        if (secao.closest('#secaoFinalizados') && !colapsoFinalizados.classList.contains('show')) {
                            new bootstrap.Collapse(colapsoFinalizados, { show: true });
                        }
                    }
                }
            });
        });
    })();
</script>
