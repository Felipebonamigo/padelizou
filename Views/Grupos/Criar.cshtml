@{
    ViewData["Title"] = "Criar Grupo - Padelizou";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0" style="border-top: 4px solid var(--padel-green);">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-plus display-4" style="color: var(--padel-green);"></i>
                        <h3 class="fw-bold mt-2" style="color: var(--padel-blue);">Criar Grupo</h3>
                        <p class="text-muted">Um ranking só seu, pros jogos semanais com a turma.</p>
                    </div>

                    <form asp-controller="Grupos" asp-action="Criar" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Nome do grupo</label>
                            <input type="text" name="nome" class="form-control bg-light" required placeholder="Ex: Nata Padel" />
                        </div>
                        <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill">Criar Grupo</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
