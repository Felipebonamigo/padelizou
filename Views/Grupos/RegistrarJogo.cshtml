@{
    ViewData["Title"] = "Registrar Jogo - Padelizou";
    var membros = (List<Jogador>)ViewBag.Membros;
    int grupoId = ViewBag.GrupoId;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0" style="border-top: 4px solid var(--padel-green);">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-clipboard-data display-4" style="color: var(--padel-green);"></i>
                        <h3 class="fw-bold mt-2" style="color: var(--padel-blue);">Registrar Jogo</h3>
                        <p class="text-muted">Lança o placar e atualiza o ranking do grupo na hora.</p>
                    </div>

                    @if (membros.Count < 4)
                    {
                        <div class="alert alert-warning">
                            O grupo precisa de pelo menos 4 membros pra registrar um jogo (2x2). Convide mais gente com o código do grupo.
                        </div>
                    }
                    else
                    {
                        <form asp-controller="Grupos" asp-action="RegistrarJogo" method="post">
                            <input type="hidden" name="grupoId" value="@grupoId" />

                            <div class="mb-3">
                                <label class="form-label fw-bold text-muted small">Data do jogo</label>
                                <input type="date" name="dataJogo" class="form-control bg-light" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label fw-bold text-muted small">Dupla 1 - Jogador 1</label>
                                    <select name="dupla1Jogador1Id" class="form-select bg-light" required>
                                        @foreach (var m in membros)
                                        {
                                            <option value="@m.Id">@m.Nome</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold text-muted small">Dupla 1 - Jogador 2</label>
                                    <select name="dupla1Jogador2Id" class="form-select bg-light" required>
                                        @foreach (var m in membros)
                                        {
                                            <option value="@m.Id">@m.Nome</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-6">
                                    <label class="form-label fw-bold text-muted small">Dupla 2 - Jogador 1</label>
                                    <select name="dupla2Jogador1Id" class="form-select bg-light" required>
                                        @foreach (var m in membros)
                                        {
                                            <option value="@m.Id">@m.Nome</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold text-muted small">Dupla 2 - Jogador 2</label>
                                    <select name="dupla2Jogador2Id" class="form-select bg-light" required>
                                        @foreach (var m in membros)
                                        {
                                            <option value="@m.Id">@m.Nome</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-4 align-items-center">
                                <div class="col-5">
                                    <label class="form-label fw-bold text-muted small">Games Dupla 1</label>
                                    <input type="number" name="gamesDupla1" class="form-control bg-light" required min="0" />
                                </div>
                                <div class="col-2 text-center fw-bold text-muted mt-3">x</div>
                                <div class="col-5">
                                    <label class="form-label fw-bold text-muted small">Games Dupla 2</label>
                                    <input type="number" name="gamesDupla2" class="form-control bg-light" required min="0" />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill">Salvar Resultado</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
