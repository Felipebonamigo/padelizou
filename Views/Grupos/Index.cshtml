@model IEnumerable<GrupoPrivado>
@{
    ViewData["Title"] = "Meus Grupos - Padelizou";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold" style="color: var(--padel-blue);">Meus Grupos</h2>
            <p class="text-muted mb-0">Ranking interno dos seus jogos semanais, fora de torneio.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Grupos" asp-action="Entrar" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-box-arrow-in-right"></i> Entrar com código
            </a>
            <a asp-controller="Grupos" asp-action="Criar" class="btn btn-padel rounded-pill">
                <i class="bi bi-plus-circle"></i> Criar Grupo
            </a>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var grupo in Model)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h5 class="fw-bold" style="color: var(--padel-blue);"><i class="bi bi-shield-lock-fill text-success"></i> @grupo.Nome</h5>
                            <p class="text-muted small mb-3">Código de convite: <code>@grupo.CodigoConvite</code></p>
                            <a asp-controller="Grupos" asp-action="Detalhes" asp-route-id="@grupo.Id" class="btn btn-sm btn-padel w-100 rounded-pill">Ver Ranking</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 rounded-3 bg-light" style="border: 2px dashed #ccc;">
                <i class="bi bi-people display-4 text-muted mb-3"></i>
                <h4 class="fw-bold text-secondary">Você ainda não está em nenhum grupo</h4>
                <p class="text-muted">Crie um grupo com seus amigos ou entre em um com um código de convite.</p>
            </div>
        }
    </div>
</div>
