@model IEnumerable<GrupoPrivado>
@using System.Security.Claims
@{
    ViewData["Title"] = "Meus Grupos - Padelizou";
    var userId = User.Identity!.IsAuthenticated ? int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!) : 0;
    var convitesPendentes = (List<ConfirmacaoSessao>)ViewBag.ConvitesPendentes;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold" style="color: var(--pdz-ink);">Meus Grupos</h2>
            <p class="text-muted mb-0">Ranking interno dos seus jogos semanais, fora de torneio.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Grupos" asp-action="Entrar" class="btn btn-outline-primary rounded-pill">
                <i class="bi bi-box-arrow-in-right"></i> Entrar com código
            </a>
            <a asp-controller="Grupos" asp-action="Criar" class="btn btn-padel rounded-pill">
                <i class="bi bi-plus-circle"></i> Criar Grupo
            </a>
        </div>
    </div>

    @if (convitesPendentes.Any())
    {
        <div class="card shadow-sm border-0 mb-4" style="border-left: 4px solid var(--padel-green);">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-whatsapp text-success"></i> Convites pra jogos fixos</h6>
                @foreach (var convite in convitesPendentes)
                {
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                        <span>Você foi convidado pro jogo do grupo <strong>@convite.Sessao.Grupo.Nome</strong> dia @convite.Sessao.DataHora.ToString("dd/MM 'às' HH:mm")</span>
                        <a asp-controller="Grupos" asp-action="Semana" asp-route-grupoId="@convite.Sessao.GrupoId" asp-route-data="@convite.Sessao.DataHora.ToString("s")" class="btn btn-sm btn-padel rounded-pill">Ver e responder</a>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var grupo in Model)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h5 class="fw-bold" style="color: var(--pdz-ink);"><i class="bi bi-shield-lock-fill text-success"></i> @grupo.Nome</h5>
                            <p class="text-muted small mb-3">Código de convite: <code>@grupo.CodigoConvite</code></p>
                            <div class="d-flex gap-2">
                                <a asp-controller="Grupos" asp-action="Semana" asp-route-grupoId="@grupo.Id" class="btn btn-sm btn-padel w-100 rounded-pill">Jogo da Semana</a>
                                <a asp-controller="Grupos" asp-action="Detalhes" asp-route-id="@grupo.Id" class="btn btn-sm btn-outline-primary rounded-pill">Ranking</a>
                            </div>
                            @if (grupo.AdministradorId == userId)
                            {
                                <a asp-controller="Grupos" asp-action="Configuracoes" asp-route-id="@grupo.Id" class="btn btn-sm btn-link text-muted mt-1 px-0">
                                    <i class="bi bi-gear"></i> Configurações
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 rounded-3 bg-light" style="border: 2px dashed #ccc;">
                <i class="bi bi-people display-4 text-muted mb-3"></i>
                <h4 class="fw-bold text-secondary">Você ainda não está em nenhum grupo</h4>
                <p class="text-muted">Crie um grupo com seus amigos ou entre em um com um código de convite.</p>
            </div>
        }
    </div>
</div>
