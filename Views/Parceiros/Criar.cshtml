@{
    ViewData["Title"] = "Anunciar Vaga - Padelizou";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0" style="border-top: 4px solid var(--padel-blue);">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-plus-fill display-4" style="color: var(--padel-blue);"></i>
                        <h3 class="fw-bold mt-2" style="color: var(--padel-blue);">Procurando Parceiro</h3>
                        <p class="text-muted">Conta pra gente onde e quando é o torneio.</p>
                    </div>

                    <form asp-controller="Parceiros" asp-action="Criar" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Qual torneio / app?</label>
                            <input type="text" name="nomeTorneio" class="form-control bg-light" required placeholder="Ex: Playtomic - Torneio de Verão" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Local</label>
                            <input type="text" name="local" class="form-control bg-light" required placeholder="Ex: Padel Garden - Gravataí" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Data e horário</label>
                            <input type="datetime-local" name="dataHora" class="form-control bg-light" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Observações (opcional)</label>
                            <textarea name="observacoes" class="form-control bg-light" rows="2" placeholder="Ex: categoria 4ª, nível intermediário"></textarea>
                        </div>

                        <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill">
                            <i class="bi bi-send-fill me-1"></i> Publicar Vaga
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
