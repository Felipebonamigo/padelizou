@model IEnumerable<Padelizou.Models.Jogador>
@{
    ViewData["Title"] = "Marcar Aula - Padelizou";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0" style="border-top: 4px solid var(--padel-blue);">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-calendar-check display-4" style="color: var(--padel-blue);"></i>
                        <h3 class="fw-bold mt-2" style="color: var(--padel-blue);">Agendar Aula</h3>
                        <p class="text-muted">Escolha seu professor e defina os detalhes do treino.</p>
                    </div>

                    <form asp-controller="Aulas" asp-action="Create" method="post">

                        <!-- Seleção do Professor -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Selecione o Professor</label>
                            <select name="professorId" class="form-select bg-light" required>
                                <option value="">-- Escolha um professor disponível --</option>
                                @foreach (var prof in Model)
                                {
                                    <option value="@prof.Id">@prof.Nome</option>
                                }
                            </select>
                        </div>

                        <!-- Data e Horário -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Data e Horário</label>
                            <input type="datetime-local" name="dataHora" class="form-control bg-light" required />
                        </div>

                        <!-- Local da Aula -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Local / Clube</label>
                            <input type="text" name="local" class="form-control bg-light" required placeholder="Ex: Padel Garden - Quadra 2" />
                        </div>

                        <!-- Valor combinado (Temporariamente manual para o MVP) -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Valor da Aula (R$)</label>
                            <input type="number" name="preco" step="0.01" class="form-control bg-light" required placeholder="Ex: 120,00" />
                        </div>

                        <button type="submit" class="btn btn-padel btn-lg w-100 rounded-pill">
                            <i class="bi bi-check-circle-fill me-1"></i> Confirmar Agendamento
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>