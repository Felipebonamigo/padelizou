@model IEnumerable<padelizou.Models.Aula>
@{
    ViewData["Title"] = "Minha Agenda - Padelizou";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--padel-blue);">Minha Agenda</h2>
            <p class="text-muted mb-0">Gerencie seus treinos e alunos marcados.</p>
        </div>
        <a asp-controller="Auth" asp-action="Perfil" class="btn btn-outline-secondary rounded-pill">Voltar ao Perfil</a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var aula in Model)
            {
                // Define a cor da etiqueta dependendo do status da aula
                var badgeClass = aula.Status == "Agendada" ? "bg-primary" :
                                 (aula.Status == "Realizada" ? "bg-success" : "bg-danger");

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-left: 5px solid var(--padel-green);">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge @badgeClass text-uppercase shadow-sm">@aula.Status</span>
                                <span class="text-muted fw-bold small"><i class="bi bi-clock-history"></i> @aula.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>

                            <h5 class="fw-bold mb-1" style="color: var(--padel-blue);">
                                <i class="bi bi-person-bounding-box text-muted me-1"></i> @aula.Aluno.Nome
                            </h5>

                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @aula.Local
                            </p>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-cash text-success"></i> @aula.Preco.ToString("C")
                            </p>

                            <!-- Botões de Ação do Professor -->
                            <div class="d-grid gap-2">
                                <!-- Botão de WhatsApp (Substitua os espaços e traços do celular no C# futuramente) -->
                                <a href="https://wa.me/55@(aula.Aluno.Celular?.Replace("-", "").Replace(" ", ""))?text=Olá, @(aula.Aluno.Nome)! Tudo certo para a nossa aula de Padel dia @(aula.DataHora.ToString("dd/MM"))?"
                                   target="_blank" class="btn btn-sm btn-success rounded-pill fw-bold">
                                    <i class="bi bi-whatsapp"></i> Chamar Aluno
                                </a>

                                <!-- Só mostra a opção de Mudar Status se a aula ainda estiver "Agendada" -->
                                @if (aula.Status == "Agendada")
                                {
                                    <div class="d-flex gap-2 mt-2">
                                        <form asp-action="AtualizarStatus" method="post" class="w-50">
                                            <input type="hidden" name="aulaId" value="@aula.Id" />
                                            <input type="hidden" name="novoStatus" value="Realizada" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-check2-all"></i> Concluir</button>
                                        </form>

                                        <form asp-action="AtualizarStatus" method="post" class="w-50">
                                            <input type="hidden" name="aulaId" value="@aula.Id" />
                                            <input type="hidden" name="novoStatus" value="Cancelada" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-x-circle"></i> Cancelar</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 rounded-3 bg-light" style="border: 2px dashed #ccc;">
                <i class="bi bi-calendar-x display-4 text-muted mb-3"></i>
                <h4 class="fw-bold text-secondary">Sua agenda está livre!</h4>
                <p class="text-muted">Nenhum aluno agendou aulas com você ainda.</p>
            </div>
        }
    </div>
</div>