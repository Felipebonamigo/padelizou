@model IEnumerable<Aula>
@{
    ViewData["Title"] = "Minha Agenda - Padelizou";
    bool googleConectado = ViewBag.GoogleConectado == true;

    var todasAulas = Model?.ToList() ?? new List<Aula>();
    var seriesPendentes = todasAulas
        .Where(a => a.Status == "Pendente" && a.RecorrenciaId != null)
        .GroupBy(a => a.RecorrenciaId!.Value)
        .ToList();
    var idsEmSerie = seriesPendentes.SelectMany(g => g.Select(a => a.Id)).ToHashSet();
    var aulasIndividuais = todasAulas.Where(a => !idsEmSerie.Contains(a.Id)).ToList();
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold" style="color: var(--pdz-ink);">Minha Agenda</h2>
            <p class="text-muted mb-0">Gerencie seus locais, horários e alunos marcados.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Aulas" asp-action="AdicionarManual" class="btn btn-padel rounded-pill btn-sm">
                <i class="bi bi-plus-lg"></i> Adicionar Aula
            </a>
            <a asp-controller="Aulas" asp-action="MeusLocais" class="btn btn-outline-primary rounded-pill btn-sm">
                <i class="bi bi-geo-alt"></i> Meus Locais
            </a>
            <a asp-controller="Aulas" asp-action="MeusHorarios" class="btn btn-outline-primary rounded-pill btn-sm">
                <i class="bi bi-clock"></i> Meus Horários
            </a>
            <a asp-controller="Aulas" asp-action="Relatorio" class="btn btn-outline-primary rounded-pill btn-sm">
                <i class="bi bi-graph-up"></i> Relatório
            </a>
            @if (googleConectado)
            {
                <span class="btn btn-sm btn-success rounded-pill disabled"><i class="bi bi-check-circle"></i> Google Agenda conectada</span>
            }
            else
            {
                <a asp-controller="GoogleAuth" asp-action="Conectar" class="btn btn-sm btn-outline-danger rounded-pill">
                    <i class="bi bi-google"></i> Conectar Google Agenda
                </a>
            }
            <a asp-controller="Aulas" asp-action="MinhasCidades" class="btn btn-outline-primary rounded-pill btn-sm">
                <i class="bi bi-pin-map"></i> Minhas Cidades
            </a>
            <a asp-controller="Aulas" asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill btn-sm">Voltar ao Painel</a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">@TempData["Erro"]</div>
    }
    @if (TempData["WhatsAppLink"] != null)
    {
        <div class="alert alert-light border d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2">
            <span>Quer avisar o aluno pelo WhatsApp também?</span>
            <a href="@TempData["WhatsAppLink"]" target="_blank" class="btn btn-sm btn-success rounded-pill fw-bold align-self-start align-self-sm-auto">
                <i class="bi bi-whatsapp"></i> Avisar aluno
            </a>
        </div>
    }

    @if (seriesPendentes.Any())
    {
        <div class="row">
            @foreach (var serie in seriesPendentes)
            {
                var aulasDaSerie = serie.OrderBy(a => a.DataHora).ToList();
                var primeira = aulasDaSerie[0];
                var nomeAlunoSerie = primeira.Aluno?.Nome ?? primeira.NomeAlunoAvulso ?? "Aluno avulso";

                <div class="col-12 mb-4">
                    <div class="card shadow-sm border-0" style="border-left: 5px solid var(--pdz-navy-fixed);">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                <h5 class="fw-bold mb-0" style="color: var(--pdz-ink);">
                                    <i class="bi bi-arrow-repeat"></i> Série de @aulasDaSerie.Count aula(s) — @nomeAlunoSerie
                                </h5>
                                <span class="text-muted small"><i class="bi bi-geo-alt-fill text-danger"></i> @primeira.LocalAula.Nome</span>
                            </div>

                            <ul class="list-unstyled small text-muted mb-3">
                                @foreach (var aula in aulasDaSerie)
                                {
                                    <li class="d-flex justify-content-between align-items-center py-1 flex-wrap gap-2 border-bottom">
                                        <span>@aula.DataHora.ToString("dd/MM/yyyy HH:mm") — @aula.Preco.ToString("C")</span>
                                        <div class="d-flex gap-1">
                                            <form asp-action="ConfirmarSolicitacao" method="post">
                                                <input type="hidden" name="aulaId" value="@aula.Id" />
                                                <input type="hidden" name="aceitar" value="true" />
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Aceitar só esta"><i class="bi bi-check2"></i></button>
                                            </form>
                                            <form asp-action="ConfirmarSolicitacao" method="post">
                                                <input type="hidden" name="aulaId" value="@aula.Id" />
                                                <input type="hidden" name="aceitar" value="false" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Recusar só esta"><i class="bi bi-x"></i></button>
                                            </form>
                                        </div>
                                    </li>
                                }
                            </ul>

                            <div class="d-flex gap-2">
                                <form asp-action="ConfirmarSerie" method="post" class="w-50">
                                    <input type="hidden" name="recorrenciaId" value="@serie.Key" />
                                    <input type="hidden" name="aceitar" value="true" />
                                    <button type="submit" class="btn btn-success w-100"><i class="bi bi-check2-all"></i> Aceitar todas</button>
                                </form>
                                <form asp-action="ConfirmarSerie" method="post" class="w-50">
                                    <input type="hidden" name="recorrenciaId" value="@serie.Key" />
                                    <input type="hidden" name="aceitar" value="false" />
                                    <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-x-circle"></i> Recusar todas</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="row">
        @if (aulasIndividuais.Any())
        {
            @foreach (var aula in aulasIndividuais)
            {
                var badgeClass = aula.Status switch
                {
                    "Pendente" => "bg-warning text-dark",
                    "Confirmada" => "bg-primary",
                    "Realizada" => "bg-success",
                    _ => "bg-danger"
                };

                var nomeAluno = aula.Aluno?.Nome ?? aula.NomeAlunoAvulso ?? "Aluno avulso";
                var telefoneAluno = aula.Aluno?.Celular ?? aula.TelefoneAlunoAvulso;
                var mensagemWhats = $"Olá, {nomeAluno}! Tudo certo para a nossa aula de Padel dia {aula.DataHora:dd/MM}?";
                var linkWhatsApp = string.IsNullOrEmpty(telefoneAluno) ? null : WhatsAppLinkHelper.GerarLink(telefoneAluno, mensagemWhats);

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-left: 5px solid var(--padel-green);">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge @badgeClass text-uppercase shadow-sm">@aula.Status</span>
                                <span class="text-muted fw-bold small"><i class="bi bi-clock-history"></i> @aula.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>

                            <h5 class="fw-bold mb-1" style="color: var(--pdz-ink);">
                                <i class="bi bi-person-bounding-box text-muted me-1"></i> @nomeAluno
                                @if (aula.RecorrenciaId != null)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle rounded-pill ms-1" style="font-size:0.65rem;">
                                        <i class="bi bi-arrow-repeat"></i> Recorrente
                                    </span>
                                }
                            </h5>

                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @aula.LocalAula.Nome
                            </p>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-cash text-success"></i> @aula.Preco.ToString("C")
                            </p>

                            <div class="d-grid gap-2">
                                @if (aula.Status == "Pendente")
                                {
                                    <div class="d-flex gap-2">
                                        <form asp-action="ConfirmarSolicitacao" method="post" class="w-50">
                                            <input type="hidden" name="aulaId" value="@aula.Id" />
                                            <input type="hidden" name="aceitar" value="true" />
                                            <button type="submit" class="btn btn-sm btn-success w-100"><i class="bi bi-check2"></i> Aceitar</button>
                                        </form>
                                        <form asp-action="ConfirmarSolicitacao" method="post" class="w-50">
                                            <input type="hidden" name="aulaId" value="@aula.Id" />
                                            <input type="hidden" name="aceitar" value="false" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-x"></i> Recusar</button>
                                        </form>
                                    </div>
                                }
                                else if (linkWhatsApp != null)
                                {
                                    <a href="@linkWhatsApp" target="_blank" class="btn btn-sm btn-success rounded-pill fw-bold">
                                        <i class="bi bi-whatsapp"></i> Chamar Aluno
                                    </a>
                                }

                                @if (aula.Status == "Confirmada")
                                {
                                    <div class="d-flex gap-2 mt-2">
                                        <form asp-action="AtualizarStatus" method="post" class="w-50">
                                            <input type="hidden" name="aulaId" value="@aula.Id" />
                                            <input type="hidden" name="novoStatus" value="Realizada" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-check2-all"></i> Concluir</button>
                                        </form>

                                        <form asp-action="AtualizarStatus" method="post" class="w-50 form-cancelar-aula" data-datahora="@aula.DataHora.ToString("o")">
                                            <input type="hidden" name="aulaId" value="@aula.Id" />
                                            <input type="hidden" name="novoStatus" value="Cancelada" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-x-circle"></i> Cancelar</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else if (!seriesPendentes.Any())
        {
            <div class="col-12 text-center py-5 rounded-3 bg-light" style="border: 2px dashed #ccc;">
                <i class="bi bi-calendar-x display-4 text-muted mb-3"></i>
                <h4 class="fw-bold text-secondary">Sua agenda está livre!</h4>
                <p class="text-muted">Nenhum aluno agendou aulas com você ainda.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.form-cancelar-aula').on('submit', function (e) {
                var dataHora = new Date($(this).data('datahora'));
                var horasRestantes = (dataHora - new Date()) / (1000 * 60 * 60);

                var mensagem = horasRestantes < 24
                    ? 'Essa aula é em menos de 24 horas. Pela política do Padelizou, o aluno deve ser cobrado normalmente mesmo com o cancelamento. Confirmar o cancelamento mesmo assim?'
                    : 'Confirmar o cancelamento desta aula?';

                if (!confirm(mensagem)) {
                    e.preventDefault();
                }
            });
        });
    </script>
}
