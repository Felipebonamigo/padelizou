@model IEnumerable<LocalAula>
@{
    ViewData["Title"] = "Meus Locais - Padelizou";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--padel-blue);">Meus Locais</h2>
            <p class="text-muted mb-0">Cadastre os lugares onde você dá aula.</p>
        </div>
        <a asp-controller="Aulas" asp-action="MinhaAgenda" class="btn btn-outline-secondary rounded-pill">Voltar à Agenda</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold text-muted mb-3">Novo local</h6>
            <form asp-controller="Aulas" asp-action="CriarLocal" method="post" class="row g-2">
                <div class="col-md-3">
                    <input type="text" name="nome" class="form-control" placeholder="Nome (ex: Padel Garden - Quadra 2)" required />
                </div>
                <div class="col-md-3">
                    <input type="text" name="endereco" class="form-control" placeholder="Endereço" required />
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" name="precoPadrao" class="form-control" placeholder="Preço da aula (R$)" required />
                </div>
                <div class="col-md-2">
                    <input type="number" step="0.01" name="custoPorAula" class="form-control" placeholder="Custo p/ o local (opcional)" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-padel w-100 rounded-pill">Adicionar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var local in Model)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card shadow-sm border-0 h-100 @(local.Ativo ? "" : "opacity-50")">
                        <div class="card-body">
                            <h5 class="fw-bold mb-1" style="color: var(--padel-blue);">@local.Nome</h5>
                            <p class="text-muted small mb-1"><i class="bi bi-geo-alt-fill text-danger"></i> @local.Endereco</p>
                            <p class="text-muted small mb-1"><i class="bi bi-cash text-success"></i> Cobra @local.PrecoPadrao.ToString("C")</p>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-wallet2 text-danger"></i>
                                @(local.CustoPorAula.HasValue ? $"Paga {local.CustoPorAula.Value:C} ao local" : "Sem custo informado")
                            </p>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-box-seam text-primary"></i>
                                @(local.PacoteAtivo && local.PacotePreco.HasValue
                                    ? $"Pacote de {local.PacoteQuantidadeAulas} aulas por {local.PacotePreco.Value:C}"
                                    : "Sem pacote de aulas")
                            </p>

                            <form asp-controller="Aulas" asp-action="AtualizarCustoLocal" method="post" class="d-flex gap-2 mb-2">
                                <input type="hidden" name="id" value="@local.Id" />
                                <input type="number" step="0.01" name="custoPorAula" class="form-control form-control-sm" placeholder="Custo por aula" value="@local.CustoPorAula" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary text-nowrap">Salvar</button>
                            </form>

                            <form asp-controller="Aulas" asp-action="AtualizarPacoteLocal" method="post" class="mb-2 p-2 rounded" style="background:#f8f9fa;">
                                <input type="hidden" name="id" value="@local.Id" />
                                <div class="form-check mb-2">
                                    <input type="checkbox" class="form-check-input" id="pacoteAtivo-@local.Id" name="pacoteAtivo" value="true" @(local.PacoteAtivo ? "checked" : "") />
                                    <label class="form-check-label small fw-bold" for="pacoteAtivo-@local.Id">Oferecer pacote de aulas</label>
                                </div>
                                <div class="d-flex gap-2">
                                    <input type="number" min="2" name="pacoteQuantidadeAulas" class="form-control form-control-sm" placeholder="Qtd. aulas" value="@(local.PacoteQuantidadeAulas ?? 4)" />
                                    <input type="number" step="0.01" min="0" name="pacotePreco" class="form-control form-control-sm" placeholder="Preço do pacote (R$)" value="@local.PacotePreco" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">Salvar</button>
                                </div>
                            </form>

                            <form asp-controller="Aulas" asp-action="AlternarLocal" method="post">
                                <input type="hidden" name="id" value="@local.Id" />
                                <button type="submit" class="btn btn-sm @(local.Ativo ? "btn-outline-danger" : "btn-outline-success") w-100">
                                    @(local.Ativo ? "Desativar" : "Reativar")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 rounded-3 bg-light" style="border: 2px dashed #ccc;">
                <p class="text-muted mb-0">Você ainda não cadastrou nenhum local.</p>
            </div>
        }
    </div>
</div>
