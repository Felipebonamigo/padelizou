@model Clube
@{
    ViewData["Title"] = $"Gerenciar {Model.Nome} - Padelizou";
    var souDono = (bool)ViewBag.SouDono;
    var administradores = (List<ClubeAdministrador>)ViewBag.Administradores;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold" style="color: var(--pdz-ink);">@Model.Nome</h2>
            <p class="text-muted mb-0">
                Dono: @(Model.Dono != null ? Model.Dono.Nome : "—")
            </p>
        </div>
        <a asp-controller="RaqueteLivre" asp-action="Criar" asp-route-clubeId="@Model.Id" class="btn btn-padel rounded-pill">
            <i class="bi bi-megaphone"></i> Publicar Raquete Livre
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h6 class="fw-bold text-muted mb-3">Administradores</h6>
            <div class="list-group mb-3">
                @if (administradores.Any())
                {
                    @foreach (var admin in administradores)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@admin.Jogador.Nome</span>
                            @if (souDono)
                            {
                                <form asp-controller="Clubes" asp-action="RemoverAdministrador" method="post">
                                    <input type="hidden" name="clubeId" value="@Model.Id" />
                                    <input type="hidden" name="jogadorId" value="@admin.JogadorId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                                </form>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="list-group-item text-muted">Nenhum administrador ainda.</div>
                }
            </div>

            <label class="form-label fw-bold small">Adicionar administrador (por CPF ou login)</label>
            @{
                ViewData["BuscaOrgActionUrl"] = Url.Action("AdicionarAdministrador", "Clubes");
                ViewData["BuscaOrgExtraFieldName"] = "clubeId";
                ViewData["BuscaOrgExtraFieldValue"] = Model.Id;
            }
            <partial name="_BuscaOrganizador" />
            @{
                ViewData["BuscaOrgActionUrl"] = null;
                ViewData["BuscaOrgExtraFieldName"] = null;
                ViewData["BuscaOrgExtraFieldValue"] = null;
            }
        </div>
    </div>
</div>
